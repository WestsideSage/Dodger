      </div>

      <fieldset style={{ margin: 0, padding: 0, border: 'none' }}>
        <legend style={{ padding: 0, fontSize: '0.6875rem', fontFamily: 'var(--font-display)', textTransform: 'uppercase', letterSpacing: '0.1em', color: '#64748b', marginBottom: '0.5rem' }}>
          Coaching Archetype
