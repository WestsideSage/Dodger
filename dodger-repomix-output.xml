      </div>

      <div>
        <label
          htmlFor="coach-name"
          style={{ display: 'block', fontSize: '0.6875rem', fontFamily: 'var(--font-display)', textTransform: 'uppercase', letterSpacing: '0.1em', color: '#64748b', marginBottom: '0.375rem' }}
        >
          Coach Name
        </label>
        <input
