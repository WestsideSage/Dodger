    events = [json.loads(item[0]) for item in events_cursor.fetchall()]
    return {
        "match_id": row["id"],
        "seed": row["seed"],
        "config_version": row["config_version"],
        "winner_team_id": row["winner_team_id"],
        "team_a_id": row["team_a_id"],
