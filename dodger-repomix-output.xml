    assert len(balls) == 5
    assert sum(1 for b in balls if b.side == "A") == 2
    assert sum(1 for b in balls if b.side == "B") == 2
    assert sum(1 for b in balls if b.side is None) == 1


def test_activate_ball_marks_held_and_emits_rule_11_event():
