# OS files
.DS_Store
Thumbs.db

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Local worktree folders if someone creates them inside the repo by mistake.
.worktrees/
worktrees/

# Local environment files
.env
.env.*
!.env.example

# Local playthrough / QA artifacts
/0*.png
/1*.png
.playwright-mcp/

# Playtest scratch scripts and screenshot dumps
playtest_*.py
playtest_shots*/
playtest_screenshots*/
playtest_full_ss/
playtest_ss*/
dodgeball-playtest-*.png

# === .gitignore blitz 2026-06-22 ===
# AI / dev tool local state (not project source). Keep intentional configs;
# ignore the rest of each tool dir.
.superpowers/
.codex/
.gemini/*
!.gemini/settings.json
opencode.json

# Scratch / throwaway working dirs
scratch/
playtest_output/

# Playtest journals & notes (findings live in commit history + docs/)
PLAYTEST_JOURNAL_*.md

# Repo-pack / LLM context dumps (generated, large)
*repomix-output.*

# Root-level screenshots & QA image dumps (real images belong in docs/ or frontend/)
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp

# Misc generated build/runtime artifacts
*.tsbuildinfo
*.pid
