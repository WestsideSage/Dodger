                "thrower_consistency_modifier": 1.0,
                "target_consistency_modifier": 1.0,
            },
        },
        "probabilities": {"p_on_target": 0.74, "p_catch": 0.31},
        "rolls": {"on_target": 0.3, "catch": 0.6},
