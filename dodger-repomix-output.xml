.dm-hub-score-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  max-width: 43rem;
  margin-top: 2rem;
  border-top: 1px solid rgba(148,163,184,0.3);
  border-bottom: 1px solid rgba(148,163,184,0.18);
}

.dm-hub-score-strip div {
  min-width: 0;
  padding: 0.9rem 1rem 0.9rem 0;
}

.dm-hub-score-strip div + div {
  border-left: 1px solid rgba(148,163,184,0.18);
  padding-left: 1rem;
}

.dm-hub-score-strip span,
.dm-hub-match-label {
  display: block;
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.65rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.dm-hub-score-strip strong {
  display: block;
  overflow: hidden;
  margin-top: 0.25rem;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  text-overflow: ellipsis;
  text-transform: uppercase;
  white-space: nowrap;
}

.dm-hub-match-card {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-width: 0;
  border-left: 1px solid rgba(148,163,184,0.22);
  background:
    linear-gradient(180deg, rgba(15, 23, 42, 0.52), rgba(2, 6, 23, 0.84)),
    rgba(15, 23, 42, 0.64);
  padding: clamp(1.25rem, 3vw, 1.75rem);
}

.dm-hub-match-card strong {
  display: block;
  margin-top: 0.55rem;
  color: #fff;
  font-family: var(--font-display);
  font-size: 2.1rem;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1;
  text-transform: uppercase;
}

.dm-hub-match-card span:last-of-type {
  margin-top: 0.65rem;
  color: #94a3b8;
  font-size: 0.85rem;
}

.dm-hub-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(19rem, 0.65fr);
  gap: 1.25rem;
  align-items: start;
}

.dm-hub-section-title {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
}

.dm-hub-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1px;
  overflow: hidden;
  border: 1px solid #1e293b;
  background: #1e293b;
}

.dm-hub-action {
  display: flex;
  min-height: 8.5rem;
  width: 100%;
  flex-direction: column;
  justify-content: space-between;
  border: 0;
  background: #0f172a;
  padding: 1rem;
  text-align: left;
  cursor: pointer;
  transition: background 160ms ease, transform 160ms ease, box-shadow 160ms ease;
}

.dm-hub-action:hover:not(:disabled) {
  background: #111c33;
  box-shadow: inset 0 0 0 1px rgba(34,211,238,0.2);
  transform: translateY(-1px);
}

.dm-hub-action:disabled {
  cursor: default;
  opacity: 0.45;
}

.dm-hub-action-primary {
  background:
    linear-gradient(180deg, rgba(249,115,22,0.16), rgba(15, 23, 42, 0.96)),
    #0f172a;
}

.dm-hub-action-accent {
  background:
    linear-gradient(180deg, rgba(34,211,238,0.12), rgba(15, 23, 42, 0.96)),
    #0f172a;
}

.dm-hub-action-title {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  line-height: 1.1;
  text-transform: uppercase;
}

.dm-hub-action-primary .dm-hub-action-title {
  color: #fb923c;
}

.dm-hub-action-accent .dm-hub-action-title {
  color: #22d3ee;
}

.dm-hub-action-detail {
  display: block;
  margin-top: 1.25rem;
  color: #64748b;
  font-size: 0.78rem;
  line-height: 1.45;
}

.dm-hub-side {
  position: sticky;
  top: 5.25rem;
}

.dm-hub-fixtures {
  border-top: 1px solid #1e293b;
  padding: 1rem 1.25rem;
}

.dm-hub-fixtures .dm-kicker {
  margin-bottom: 0.75rem;
}

.dm-hub-fixture {
  display: grid;
  grid-template-columns: 3rem minmax(0, 1fr);
  gap: 0.75rem;
  align-items: center;
  border-top: 1px solid rgba(30,41,59,0.75);
  padding: 0.75rem 0;
}

.dm-hub-fixture:first-of-type {
  border-top: 0;
}

.dm-hub-fixture span {
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.75rem;
}

.dm-hub-fixture strong {
  overflow: hidden;
  color: #cbd5e1;
  font-size: 0.82rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dm-replay-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.7fr) minmax(320px, 0.75fr);
  align-items: start;
  overflow: visible;
}

.dm-replay-stage {
  min-width: 0;
  display: flex;
  flex-direction: column;
  border-right: 1px solid #1e293b;
  overflow: hidden;
}

.dm-replay-court {
  padding: 12px 12px 4px;
  background: #020617;
}

.dm-replay-controls {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  background: #020617;
  border-top: 1px solid #1e293b;
  border-bottom: 1px solid #1e293b;
}

.dm-replay-scrubber {
  flex: 1 1 7rem;
  min-width: 5rem;
}

.dm-replay-sidebar {
  min-width: 0;
  display: flex;
  flex-direction: column;
  max-height: min(78vh, 820px);
  overflow: hidden;
  background: #020617;
}

.dm-hub-fixture-user strong {
  color: #fff;
}

.dm-kicker {
  font-family: var(--font-mono-data);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.24em;
  color: #22d3ee;
}

.dm-table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
}

.dm-table thead tr {
  border-bottom: 1px solid #1e293b;
  background: #020617;
}

.dm-table th {
  padding: 0.75rem 1rem;
  font-family: var(--font-display);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #64748b;
}

.dm-table tbody tr {
  border-bottom: 1px solid rgba(30, 41, 59, 0.7);
  transition: background-color 120ms;
}

.dm-table tbody tr:last-child {
  border-bottom: none;
}

.dm-table tbody tr:hover {
  background: rgba(30, 41, 59, 0.5);
}

.dm-table td {
  padding: 0.75rem 1rem;
  font-size: 0.875rem;
}

.dm-nav-item {
  display: flex;
  width: 100%;
  align-items: center;
  gap: 0.75rem;
  border-left: 2px solid transparent;
  padding: 0.75rem 1rem;
  text-align: left;
  font-family: var(--font-display);
  font-size: 0.8125rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #94a3b8;
  transition: all 150ms;
  background: transparent;
  border-top: none;
  border-right: none;
  border-bottom: none;
  cursor: pointer;
  white-space: nowrap;
}

.dm-nav-label-short {
  display: none;
}

.dm-nav-item:hover {
  border-left-color: #475569;
  background: rgba(30, 41, 59, 0.6);
  color: #e2e8f0;
}

.dm-nav-item-active {
  border-left-color: #22d3ee !important;
  background: rgba(22, 78, 99, 0.4) !important;
  color: #67e8f9 !important;
}

.dm-nav-dot {
  width: 6px;
  height: 6px;
  border-radius: 9999px;
  background: #475569;
  flex-shrink: 0;
  transition: background-color 150ms;
}

.dm-nav-item-active .dm-nav-dot {
  background: #22d3ee;
}

.dm-badge {
  display: inline-flex;
  align-items: center;
  border: 1px solid #334155;
  background: #1e293b;
  padding: 0.125rem 0.375rem;
  font-family: var(--font-mono-data);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #94a3b8;
}

.dm-badge-cyan {
  border-color: rgba(34,211,238,0.3);
  background: rgba(34,211,238,0.10);
  color: #67e8f9;
}

.dm-badge-orange {
  border-color: rgba(249,115,22,0.3);
  background: rgba(249,115,22,0.10);
  color: #fb923c;
}

.dm-badge-rose {
  border-color: rgba(244,63,94,0.3);
  background: rgba(244,63,94,0.10);
  color: #fb7185;
}

.dm-badge-emerald {
  border-color: rgba(16,185,129,0.3);
  background: rgba(16,185,129,0.10);
  color: #34d399;
}

.dm-badge-amber {
  border-color: rgba(245,158,11,0.3);
  background: rgba(245,158,11,0.10);
  color: #fbbf24;
}

.dm-badge-violet {
  border-color: rgba(167,139,250,0.3);
  background: rgba(167,139,250,0.10);
  color: #c4b5fd;
}

.dm-badge-slate {
  border-color: rgba(100,116,139,0.3);
  background: rgba(100,116,139,0.10);
  color: #94a3b8;
}

.dm-data {
  font-family: var(--font-mono-data);
  font-variant-numeric: tabular-nums;
}

.dm-desktop-only { display: inline; }
.dm-mobile-only  { display: none; }

.dm-display {
  font-family: var(--font-display);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.dm-scoreboard-tile {
  border: 1px solid #334155;
  background: #020617;
  padding: 1rem 1.25rem;
  box-shadow: 0 0 24px rgba(249,115,22,0.16);
}

.dm-glow-cyan { box-shadow: 0 0 18px rgba(6,182,212,0.28); }
.dm-glow-orange { box-shadow: 0 0 18px rgba(249,115,22,0.28); }
.dm-glow-rose { box-shadow: 0 0 18px rgba(244,63,94,0.28); }

.dm-spotlight {
  border: 1px solid rgba(249,115,22,0.30);
  background: rgba(249,115,22,0.10);
  padding: 1.25rem 1.5rem;
  box-shadow: 0 0 24px rgba(249,115,22,0.18);
}

.dm-telemetry {
  border: 1px solid #1e293b;
  background: #020617;
  font-family: var(--font-mono-data);
  font-size: 0.875rem;
}

.dm-telemetry-header {
  border-bottom: 1px solid #1e293b;
  padding: 0.75rem 1rem;
  font-family: var(--font-display);
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #64748b;
}

.dm-telemetry-row {
  padding: 0.75rem 1rem;
  border-bottom: 1px solid rgba(30, 41, 59, 0.7);
  color: #94a3b8;
}

.dm-telemetry-row:last-child {
  border-bottom: none;
}

.dm-stat-bar-track {
  height: 6px;
  width: 4rem;
  overflow: hidden;
  border-radius: 9999px;
  background: #1e293b;
  flex-shrink: 0;
}

.dm-tactic-slider {
  border-top: 1px solid #1e293b;
  padding: 1rem 1.25rem;
}

.dm-tactic-slider input[type="range"] {
  width: 100%;
  height: 6px;
  cursor: pointer;
  appearance: none;
  background: #1e293b;
  border-radius: 9999px;
  accent-color: #f97316;
}

.dm-divider {
  border: none;
  border-top: 1px solid #1e293b;
}

.dm-workspace {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  overflow-x: hidden;
}

.dm-content {
  flex: 1;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.dm-helper-copy {
  color: #94a3b8;
  font-size: 0.78rem;
  line-height: 1.4;
}

.dm-helper-copy-warning {
  color: #f59e0b;
}

/* Two-column desktop layouts used by Hub and CommandCenter. Stack on mobile,
   side-by-side at lg/xl. The classes are referenced from JSX as bare class
   names (no Tailwind breakpoint prefix), so they live here in plain CSS.
   Each class sets display+gap so JSX does not need an inline grid override. */
.lg-two-col-hub,
.lg-two-col-roster,
.xl-two-col {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
}

@media (min-width: 1024px) {
  .lg-two-col-hub,
  .lg-two-col-roster {
    grid-template-columns: 1.2fr 0.8fr;
  }
}

@media (min-width: 1280px) {
  .xl-two-col {
    grid-template-columns: 1.1fr 0.9fr;
  }
}

@media (max-width: 1080px) {
  .dm-hub-hero,
  .dm-hub-grid {
    grid-template-columns: 1fr;
  }

  .dm-hub-hero-main h1 {
    font-size: 4.5rem;
  }

  .dm-hub-match-card {
    border-top: 1px solid rgba(148,163,184,0.22);
    border-left: 0;
  }

  .dm-hub-side {
    position: static;
  }

  .dm-command-report-lanes {
    grid-template-columns: 1fr;
  }

  .dm-command-report-lane-primary {
    grid-row: auto;
  }

  .dm-replay-layout {
    grid-template-columns: 1fr;
  }

  .dm-replay-stage {
    border-right: 0;
    border-bottom: 1px solid #1e293b;
  }

  .dm-replay-sidebar {
    max-height: none;
    overflow: visible;
  }
}

@media (max-width: 720px) {
  .dm-app-shell.flex {
    flex-direction: column;
  }

  .dm-left-nav {
    width: 100%;
    min-height: auto;
    border-right: 0;
    border-bottom: 1px solid #1e293b;
  }

  .dm-left-nav-logo {
    display: flex;
    align-items: end;
    justify-content: space-between;
    padding: 0.75rem 1rem;
  }

  .dm-left-nav nav[aria-label="Primary"] {
    display: flex;
    flex: none !important;
    gap: 0.25rem;
    overflow-x: auto;
    padding: 0.25rem 0.75rem 0.75rem !important;
    scrollbar-width: none;
  }

  .dm-left-nav nav[aria-label="Primary"]::-webkit-scrollbar {
    display: none;
  }

  .dm-left-nav > div:last-child {
    display: none;
  }

  .dm-nav-item {
    width: auto;
    flex: 0 0 auto;
    min-height: 2.5rem;
    border-left: 0;
    border-bottom: 2px solid transparent;
    padding: 0.625rem 0.75rem;
  }

  .dm-nav-item:hover,
  .dm-nav-item-active {
    border-left-color: transparent !important;
    border-bottom-color: #22d3ee !important;
  }

  .dm-workspace {
    min-height: auto;
  }

  .dm-content {
    padding: 1rem;
  }

  .dm-hub-hero {
    min-height: auto;
  }

  .dm-hub-hero-main h1 {
    font-size: 2.4rem;
  }

  .dm-hub-court-mark {
    width: calc(100% - 2rem);
    opacity: 0.18;
  }

  .dm-desktop-only { display: none; }
  .dm-mobile-only  { display: inline; }

  .dm-hub-score-strip,
  .dm-hub-action-grid {
    grid-template-columns: 1fr;
  }

  .dm-hub-score-strip div + div {
    border-top: 1px solid rgba(148,163,184,0.18);
    border-left: 0;
    padding-left: 0;
  }

  .dm-hub-action {
    min-height: 6.5rem;
  }

  .dm-hub-section-title {
    flex-direction: column;
  }

  .dm-command-report-lane {
    grid-template-columns: 1fr;
    min-height: auto;
  }

  .dm-command-report-items {
    grid-column: auto;
  }

  .dm-hub-fixture {
    align-items: start;
  }

  .dm-hub-fixture strong {
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
    line-height: 1.35;
  }

  .dm-replay-court {
    padding: 10px 10px 4px;
  }

  .dm-replay-controls {
    flex-wrap: wrap;
    align-items: center;
  }

  .dm-replay-scrubber {
    flex-basis: 100%;
    order: 10;
  }

}

/* === COMMAND CENTER === */
.command-home {
  display: flex;
  width: min(100%, 1440px);
  margin: 0 auto;
  flex-direction: column;
  gap: 1.25rem;
}

.command-home-header-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 1.25rem;
  align-items: end;
}

.command-home-state-card {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 0.85rem;
  align-items: center;
  min-width: 19rem;
  min-height: 4.25rem;
  padding: 0.9rem 1rem;
  border-left: 2px solid rgba(34,211,238,0.6);
  background: rgba(15,23,42,0.78);
}

.command-home-state-card > span {
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.command-home-state-card p,
.command-home-state-card strong {
  margin: 0;
  font-family: var(--font-display);
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-home-state-card p {
  color: #94a3b8;
  font-size: 0.72rem;
}

.command-home-state-card strong {
  color: #f8fafc;
  font-size: 0.9rem;
}

.command-home-hero-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.36fr);
  gap: 1.5rem;
  align-items: stretch;
  min-height: 22rem;
  padding: clamp(1.25rem, 2.6vw, 2rem);
  border-color: rgba(34,211,238,0.28);
  background:
    linear-gradient(105deg, rgba(8,47,73,0.36), transparent 34%),
    linear-gradient(180deg, rgba(15,23,42,0.94), rgba(2,6,23,0.92)),
    #0f172a;
  box-shadow: 0 22px 60px rgba(0,0,0,0.26);
}

.command-home-hero-copy {
  display: grid;
  align-content: space-between;
  gap: 1.2rem;
  min-width: 0;
}

.command-home-hero-copy h2 {
  max-width: 13ch;
  margin: 0;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: clamp(3rem, 6vw, 5.8rem);
  font-weight: 900;
  letter-spacing: 0;
  line-height: 0.95;
  text-transform: uppercase;
}

.command-home-hero-copy > p:not(.dm-kicker) {
  max-width: 50rem;
  margin: 0;
  color: #cbd5e1;
  font-size: 1rem;
  line-height: 1.55;
}

.command-home-hero-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  border: 1px solid rgba(51,65,85,0.8);
  background: rgba(2,6,23,0.3);
}

.command-home-hero-stats div {
  display: grid;
  gap: 0.45rem;
  min-height: 4.75rem;
  padding: 0.85rem 1rem;
  border-left: 1px solid rgba(51,65,85,0.72);
}

.command-home-hero-stats div:first-child {
  border-left: 0;
}

.command-home-hero-stats span,
.command-home-scout-grid span,
.command-home-orders span {
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.66rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.command-home-hero-stats strong,
.command-home-scout-grid strong,
.command-home-orders strong {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 0.02em;
  line-height: 1.1;
  text-transform: uppercase;
}

.command-home-hero-control {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 1.25rem;
  min-width: 0;
  border-left: 1px solid rgba(51,65,85,0.82);
  padding-left: 1.5rem;
}

.command-home-intent-field {
  display: grid;
  width: 100%;
  max-width: 18rem;
  gap: 0.55rem;
}

.command-home-intent-field select {
  min-height: 2.45rem;
  width: 100%;
  border: 1px solid #334155;
  border-radius: 4px;
  background: rgba(15,23,42,0.86);
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.06em;
  padding: 0.5rem 0.75rem;
  text-transform: uppercase;
}

.command-home-readiness {
  display: grid;
  gap: 0.4rem;
  border-top: 1px solid rgba(51,65,85,0.82);
  border-bottom: 1px solid rgba(51,65,85,0.82);
  padding: 1rem 0;
}

.command-home-readiness span {
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.command-home-readiness strong {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 1.25rem;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

.command-home-readiness p {
  margin: 0;
  color: #f59e0b;
  font-size: 0.88rem;
  line-height: 1.45;
}

.command-home-hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
  align-items: center;
}

.command-home-body-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.34fr);
  gap: 1.25rem;
  align-items: stretch;
}

.command-home-operations,
.command-home-rail {
  display: grid;
  gap: 1rem;
}

.command-home-operations > .command-home-panel {
  height: 100%;
}

.command-home-panel {
  min-width: 0;
  padding: clamp(1rem, 2vw, 1.35rem);
}

.command-home-operations .command-home-panel {
  border-color: rgba(51,65,85,0.74);
}

.command-home-rail .dm-panel {
  background: rgba(15,23,42,0.86);
}

.command-home-rail .dm-panel-header {
  padding: 1rem 1.1rem;
}

.command-program-status {
  min-width: 0;
}

.command-home-checklist-items {
  display: grid;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.command-home-checklist-items div {
  display: grid;
  gap: 0.3rem;
  border-left: 2px solid #334155;
  background: rgba(2,6,23,0.3);
  padding: 0.7rem 0.8rem;
}

.command-home-checklist-items div > span {
  color: #94a3b8;
  font-family: var(--font-mono-data);
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.command-home-checklist-items .is-ready {
  border-left-color: #10b981;
}

.command-home-checklist-items .is-ready > span {
  color: #34d399;
}

.command-home-checklist-items .is-pending {
  border-left-color: #f59e0b;
}

.command-home-checklist-items .is-pending > span {
  color: #f59e0b;
}

.command-home-checklist-items strong {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.98rem;
  font-weight: 800;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

.command-home-checklist-items p {
  margin: 0.2rem 0 0;
  color: #94a3b8;
  font-size: 0.78rem;
  line-height: 1.35;
}

.command-home-orders {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.75rem;
}

.command-home-orders div {
  display: grid;
  gap: 0.4rem;
  min-height: 7.25rem;
  border: 1px solid rgba(51,65,85,0.72);
  background: rgba(2,6,23,0.24);
  padding: 0.95rem;
}

.command-home-orders strong {
  color: #f8fafc;
  font-size: 1.05rem;
}

.command-home-orders p {
  margin: 0;
  color: #a8b3c7;
  font-size: 0.86rem;
  line-height: 1.45;
}

.command-home-scout-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0;
  border: 1px solid rgba(51,65,85,0.72);
  background: rgba(2,6,23,0.24);
}

.command-home-opponent-file {
  scroll-margin-top: 1rem;
}

.command-home-opponent-file:focus {
  outline: 1px solid rgba(34,211,238,0.45);
  outline-offset: 3px;
}

.command-home-scout-grid div {
  display: grid;
  gap: 0.45rem;
  min-height: 4.5rem;
  border-left: 1px solid rgba(51,65,85,0.72);
  padding: 0.85rem 1rem;
}

.command-home-scout-grid div:first-child {
  border-left: 0;
}

.command-home-muted-note {
  margin: 0.85rem 0 0;
  color: #94a3b8;
  font-size: 0.88rem;
  line-height: 1.45;
}

.command-post-sim {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  width: min(100%, 1280px);
  margin: -0.5rem auto 0;
  padding-bottom: 1rem;
}

.command-reveal {
  animation: command-reveal 400ms ease-out both;
}

.command-offseason-shell {
  display: flex;
  width: min(100%, 1280px);
  margin: 0 auto;
  flex-direction: column;
  gap: 1.25rem;
}

.command-offseason-progress {
  display: flex;
  align-items: center;
  gap: 0.35rem;
}

.command-offseason-progress-step {
  display: block;
  width: clamp(1rem, 3vw, 2.25rem);
  height: 0.25rem;
  border-radius: 999px;
  background: #1e293b;
}

.command-offseason-progress-step-active {
  background: #22d3ee;
  box-shadow: 0 0 14px rgba(34,211,238,0.22);
}

.command-offseason-feature {
  min-height: 16rem;
  padding: clamp(1.25rem, 3vw, 2rem);
  background:
    linear-gradient(135deg, rgba(34,211,238,0.08), transparent 38%),
    linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(2, 6, 23, 0.92)),
    #0f172a;
}

.command-offseason-feature h3 {
  max-width: 42rem;
  margin: 0.35rem 0 1.25rem;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: clamp(1.75rem, 4vw, 3.25rem);
  font-weight: 900;
  letter-spacing: 0.02em;
  line-height: 1;
  text-transform: uppercase;
}

.command-offseason-feature > p,
.command-offseason-copy {
  max-width: 46rem;
  color: #cbd5e1;
  font-size: 0.98rem;
  line-height: 1.55;
}

.command-offseason-copy {
  display: grid;
  gap: 0.45rem;
}

.command-offseason-copy p,
.command-offseason-feature > p {
  margin: 0;
}

.command-score-hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
  align-items: stretch;
  gap: 1px;
  background: #1e293b;
}

.command-score-team {
  position: relative;
  min-width: 0;
  min-height: 3.5rem;
  border: 1px solid #1e293b;
  background:
    linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(2, 6, 23, 0.94)),
    #0f172a;
  padding: clamp(0.35rem, 1vw, 0.55rem);
  transition: border-color 180ms ease, opacity 180ms ease, box-shadow 180ms ease;
}

.command-score-team-away {
  text-align: right;
}

.command-score-team-loser {
  opacity: 0.78;
}

.command-score-team strong {
  display: block;
  overflow-wrap: anywhere;
  margin-top: 0.1rem;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: clamp(0.8rem, 1.6vw, 1rem);
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1;
  text-transform: uppercase;
}

.command-score-number {
  display: block;
  margin-top: 0.15rem;
  color: #fff;
  font-family: var(--font-mono-data);
  font-size: clamp(1.4rem, 3vw, 2rem);
  font-weight: 900;
  letter-spacing: 0;
  line-height: 0.9;
}

.command-score-detail {
  display: block;
  margin-top: 0.3rem;
  color: #cbd5e1;
  font-family: var(--font-mono-data);
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-score-winner-badge {
  margin-top: 0.25rem;
}

.command-score-center {
  display: flex;
  min-width: 4.5rem;
  width: 4.5rem;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 0.35rem;
  background: #020617;
  padding: 1rem 0.75rem;
  border-left: 1px solid rgba(249, 115, 22, 0.15);
  border-right: 1px solid rgba(34, 211, 238, 0.15);
}

.command-score-vs {
  color: #1e293b;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 0.14em;
}

.command-section-heading {
  margin-bottom: 0.4rem;
}

.command-section-heading h3 {
  margin: 0.1rem 0 0;
  color: #fff;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.command-analysis-row {
  display: grid;
  grid-template-columns: 0.85fr 1.15fr;
  gap: 1rem;
  align-items: start;
}

.command-match-flow-header {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  padding: 1rem 1.25rem 0.75rem;
  flex-wrap: wrap;
}

.command-match-flow-header .dm-panel-title {
  margin: 0;
}

.command-match-flow-header ~ .command-empty-copy {
  padding: 0 1.25rem 1.25rem;
}

.command-match-flow-count {
  font-family: var(--font-mono-data);
  font-size: 0.65rem;
  color: #64748b;
  letter-spacing: 1px;
  margin-left: auto;
  align-self: center;
}

.command-match-flow-scroll-wrap {
  position: relative;
}

.command-match-flow-scroll-wrap::after {
  content: '';
  position: absolute;
  bottom: 28px;
  left: 0;
  right: 12px;
  height: 48px;
  background: linear-gradient(to bottom, transparent, rgba(15, 23, 42, 0.92));
  pointer-events: none;
}

.command-timeline-collapse-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 9px 1rem;
  background: #0f172a;
  border: none;
  border-bottom: 1px solid #1e293b;
  cursor: pointer;
  font-family: var(--font-mono-data);
  font-size: 0.65rem;
  letter-spacing: 1px;
  text-align: left;
  color: #64748b;
}

.command-timeline-collapse-bar:hover {
  background: #1e293b;
}

.command-timeline-collapse-bar:focus-visible {
  outline: 2px solid #f97316;
  outline-offset: -2px;
}

.command-timeline-collapse-label {
  display: flex;
  align-items: center;
  gap: 0;
}

.command-timeline-collapse-icon {
  font-size: 0.55rem;
  color: #475569;
  flex-shrink: 0;
}

.command-match-flow-scroll-hint {
  margin: 0;
  padding: 6px 1.25rem 1rem;
  font-family: var(--font-mono-data);
  font-size: 0.6rem;
  letter-spacing: 1px;
  color: #475569;
  text-align: center;
}

.command-match-flow-scroll {
  max-height: 560px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: #334155 transparent;
  outline-offset: 2px;
}

.command-match-flow-list {
  list-style: none;
  margin: 0;
  padding: 0 1.25rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 1.1rem;
}

.command-match-flow-event {
  display: grid;
  grid-template-columns: 1.75rem 1fr;
  gap: 0.75rem;
  align-items: start;
}

.command-event-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 1.875rem;
  height: 1.875rem;
  border-radius: 50%;
  background: #1a2234;
  border: 1px solid #2d3f58;
  color: #94a3b8;
  font-family: var(--font-mono-data);
  font-size: 0.7rem;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 0.1rem;
}

.command-event-phase {
  display: inline-block;
  font-family: var(--font-mono-data);
  font-size: 0.58rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #64748b;
  margin-bottom: 0.3rem;
}

.command-event-desc {
  margin: 0;
  font-size: 0.875rem;
  font-weight: 600;
  color: #f1f5f9;
  line-height: 1.45;
}

.command-event-items {
  margin: 0.5rem 0 0;
  padding-left: 0;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.command-event-items li {
  font-size: 0.72rem;
  color: #94a3b8;
  line-height: 1.5;
  padding-left: 0.75rem;
  border-left: 1px solid #1e293b;
}

.command-timeline-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 1.25rem;
}

.command-timeline-item {
  position: relative;
  display: grid;
  grid-template-columns: 1.25rem minmax(0, 1fr);
  gap: 0.8rem;
  padding-bottom: 1.1rem;
}

.command-timeline-item:last-child {
  padding-bottom: 0;
}

.command-timeline-item::before {
  content: '';
  position: absolute;
  left: 0.35rem;
  top: 0.85rem;
  bottom: -0.1rem;
  width: 1px;
  background: #1e293b;
}

.command-timeline-item:last-child::before {
  display: none;
}

.command-timeline-dot {
  position: relative;
  z-index: 1;
  width: 0.75rem;
  height: 0.75rem;
  margin-top: 0.25rem;
  border: 2px solid #22d3ee;
  border-radius: 999px;
  background: #020617;
  box-shadow: 0 0 16px rgba(34,211,238,0.18);
}

.command-timeline-item strong {
  display: block;
  margin-top: 0.35rem;
  color: #e2e8f0;
  font-size: 0.95rem;
  line-height: 1.45;
}

.command-timeline-item ul {
  margin: 0.65rem 0 0;
  padding-left: 1rem;
  color: #94a3b8;
  font-size: 0.8rem;
  line-height: 1.5;
}

.command-key-players .dm-panel-header {
  padding: 6px 10px;
}

.command-key-player-list {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 0.4rem 0.75rem 0.5rem;
}

.command-key-player {
  display: grid;
  grid-template-columns: 1.75rem minmax(0, 1fr);
  gap: 0.75rem;
  align-items: start;
}

.command-rank-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 1.75rem;
  height: 1.75rem;
  border-radius: 50%;
  font-family: var(--font-mono-data);
  font-size: 0.7rem;
  font-weight: 700;
  flex-shrink: 0;
  color: #fff;
}

.command-key-player strong {
  display: inline;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.82rem;
  text-transform: uppercase;
}

.command-key-player p,
.command-action-bar p {
  margin: 0.25rem 0 0;
  color: #94a3b8;
  font-size: 0.82rem;
  line-height: 1.45;
}

.command-tactical-card {
  padding: 0.85rem;
}

.command-tactical-card-footer {
  margin-top: 0.75rem;
  padding-top: 0.625rem;
  border-top: 1px solid #1e293b;
  font-family: var(--font-mono-data);
  font-size: 0.6rem;
  color: #475569;
  letter-spacing: 0.5px;
}

.command-fallout-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}

.command-fallout-card {
  padding: 0.3rem 0.5rem;
  transition: border-color 140ms ease, transform 140ms ease, box-shadow 140ms ease;
}

.command-fallout-standings-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 0.35rem;
  font-family: var(--font-mono-data);
  font-size: 0.58rem;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #64748b;
}

.command-fallout-empty {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin: 0;
  padding: 0.65rem 0;
  border-top: 1px solid #1e293b;
  color: #475569;
  font-size: 0.8rem;
  font-style: italic;
}

.command-fallout-empty::before {
  content: '—';
  color: #334155;
  font-style: normal;
  font-family: var(--font-mono-data);
  flex-shrink: 0;
}

.command-clean-list-compact li {
  padding-top: 0.45rem;
  gap: 0.5rem;
}

.command-fallout-card:hover {
  transform: translateY(-1px);
  border-color: rgba(34, 211, 238, 0.35);
  box-shadow: 0 18px 42px rgba(0,0,0,0.32);
}

.command-fallout-card-body {
  margin-top: 0.15rem;
}

.command-clean-list {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  margin: 0;
  padding: 0;
  list-style: none;
}

.command-clean-list li {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 0.5rem;
  align-items: baseline;
  border-top: 1px solid rgba(30,41,59,0.7);
  padding-top: 0;
}

.command-clean-list li:first-child {
  border-top: 0;
  padding-top: 0;
}

.command-clean-list strong {
  overflow: hidden;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.95rem;
  text-overflow: ellipsis;
  text-transform: uppercase;
  white-space: nowrap;
}

.command-clean-list span {
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.75rem;
}

.command-clean-list small {
  grid-column: 1 / -1;
  color: #94a3b8;
  font-size: 0.75rem;
  line-height: 1.45;
}

.command-clean-list-loose li {
  grid-template-columns: minmax(0, 1fr);
}

.command-empty-copy {
  margin: 0;
  color: #64748b;
  font-size: 0.88rem;
  line-height: 1.5;
}

.command-action-bar {
  display: flex;
  gap: 8px;
  align-items: stretch;
  justify-content: flex-end;
  padding: 4px 16px 12px;
}

.command-action-bar-secondary {
  flex: 0 0 auto;
  background: #1a2234;
  border: 1px solid #475569;
  border-radius: 8px;
  color: #e2e8f0;
  padding: 10px 20px;
  font-family: var(--font-display);
  font-size: 0.75rem;
  letter-spacing: 1px;
  cursor: pointer;
  white-space: nowrap;
}

.command-action-bar-secondary:hover {
  background: #1e293b;
  border-color: #64748b;
}

.command-action-bar-secondary:focus-visible {
  outline: 2px solid #f97316;
  outline-offset: 2px;
}

.command-action-bar-primary {
  flex: 0 0 auto;
  min-width: 210px;
  border: none;
  border-radius: 8px;
  background: #f97316;
  color: #fff;
  padding: 10px 20px;
  font-family: var(--font-display);
  font-size: 0.85rem;
  letter-spacing: 2px;
  cursor: pointer;
}

.command-action-bar-primary.is-advancing {
  background: #7c3d12;
  cursor: default;
}

.command-action-bar-primary:focus-visible {
  outline: 2px solid #f97316;
  outline-offset: 2px;
}

.command-action-buttons {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 0.75rem;
}

@keyframes command-reveal {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 1080px) {
  .command-home-header-row,
  .command-home-hero-card,
  .command-home-body-grid {
    grid-template-columns: 1fr;
  }

  .command-home-state-card {
    width: 100%;
  }

  .command-home-hero-control {
    border-top: 1px solid rgba(51,65,85,0.82);
    border-left: 0;
    padding-top: 1.25rem;
    padding-left: 0;
  }

  .command-fallout-grid {
    grid-template-columns: 1fr;
  }

  .command-analysis-row {
    grid-template-columns: 1fr;
  }
}

@media (min-width: 721px) and (max-width: 1023px) {
  .command-match-flow-scroll {
    max-height: 480px;
  }
}

@media (max-width: 720px) {
  .command-home-hero-stats,
  .command-home-orders,
  .command-home-scout-grid {
    grid-template-columns: 1fr;
  }

  .command-home-hero-stats div,
  .command-home-scout-grid div {
    border-left: 0;
    border-top: 1px solid rgba(51,65,85,0.72);
  }

  .command-home-hero-stats div:first-child,
  .command-home-scout-grid div:first-child {
    border-top: 0;
  }

  .command-score-hero {
    grid-template-columns: 1fr;
  }

  .command-score-center {
    min-width: 0;
    width: auto;
    min-height: 4.5rem;
    border-left: 0;
    border-right: 0;
    border-top: 1px solid rgba(249, 115, 22, 0.15);
    border-bottom: 1px solid rgba(34, 211, 238, 0.15);
  }

  .command-score-team,
  .command-score-team-away {
    text-align: left;
  }

  .command-action-bar {
    flex-direction: column;
    justify-content: stretch;
  }

  .command-action-bar-secondary,
  .command-action-bar-primary {
    width: 100%;
    min-width: 0;
    text-align: center;
  }

  .command-action-buttons,
  .command-action-buttons button {
    width: 100%;
  }

  .command-match-flow-scroll {
    max-height: none;
    overflow-y: visible;
  }

  .command-match-flow-scroll-wrap::after {
    display: none;
  }
}

/* === WEEKLY COMMAND DASHBOARD === */
.command-dashboard {
  display: grid;
  width: min(100%, 1500px);
  margin: 0 auto;
  min-height: calc(100vh - 8.2rem);
  grid-template-rows: auto auto;
  gap: 0.65rem;
  color: #e2e8f0;
  font-family: var(--font-body);
  border: 1px solid rgba(30, 41, 59, 0.95);
  border-radius: 0.8rem;
  background:
    radial-gradient(circle at top left, rgba(34, 211, 238, 0.08), transparent 24rem),
    radial-gradient(circle at top right, rgba(249, 115, 22, 0.07), transparent 22rem),
    rgba(2, 6, 23, 0.72);
  box-shadow:
    inset 0 0 0 1px rgba(15, 23, 42, 0.72),
    0 0 0 1px rgba(2, 6, 23, 0.8),
    0 18px 60px rgba(0, 0, 0, 0.38);
  padding: 0.8rem;
  overflow: hidden;
}

.command-console-header {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(18rem, 24rem);
  gap: 1rem;
  align-items: center;
  min-height: 4.2rem;
  padding: 0 0.15rem;
}

.command-console-title {
  display: flex;
  align-items: center;
  gap: 0.85rem;
}

.command-console-mark {
  display: grid;
  width: 2.8rem;
  height: 2.8rem;
  place-items: center;
  border: 1px solid rgba(34, 211, 238, 0.4);
  color: #22d3ee;
  font-size: 1.3rem;
  box-shadow: inset 0 0 18px rgba(34, 211, 238, 0.1);
}

.command-console-title span {
  display: block;
  margin-bottom: 0.15rem;
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.66rem;
  font-weight: 900;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

.command-console-title h1 {
  margin: 0;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: clamp(1.4rem, 2vw, 2rem);
  font-weight: 800;
  letter-spacing: 0.05em;
  line-height: 1;
  text-transform: uppercase;
}

.command-filter-row {
  display: flex;
  align-items: center;
}

.command-filter-row .command-strip-meta {
  width: 100%;
}

.command-cockpit-grid {
  display: grid;
  min-height: 0;
  grid-template-columns: minmax(27rem, 1.25fr) minmax(23rem, 1fr) minmax(23rem, 0.95fr);
  gap: 0.7rem;
  align-items: stretch;
}

.command-cockpit-panel {
  min-width: 0;
  min-height: 0;
  padding: 1rem 1.15rem;
}

.command-cockpit-panel .command-panel-heading {
  margin-bottom: 0.9rem;
}

.command-cockpit-panel .command-current-plan {
  max-width: 16rem;
}

.command-plan-alert {
  display: flex;
  justify-content: space-between;
  gap: 0.65rem;
  align-items: center;
  margin-bottom: 0.65rem;
}

.command-plan-alert div {
  display: grid;
  gap: 0.2rem;
  flex: 1;
  min-width: 0;
}

.command-plan-alert button,
.command-scout-response button {
  flex-shrink: 0;
  border: 1px solid rgba(245,158,11,0.35);
  background: rgba(245,158,11,0.12);
  color: #fde68a;
  cursor: pointer;
  font-size: 0.7rem;
  font-weight: 800;
  padding: 0.42rem 0.55rem;
}

.command-plan-alert span {
  color: #fca5a5;
}

.command-cockpit-panel .command-plan-grid {
  grid-template-columns: minmax(12rem, 0.95fr) minmax(13rem, 1.05fr);
  gap: 1.1rem;
}

.command-approach-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.command-cockpit-panel .command-approach-grid button {
  min-height: 3rem;
  padding: 0.5rem 0.38rem;
  overflow: hidden;
}

.command-cockpit-panel .command-approach-grid span {
  font-size: 0.68rem;
}

.command-approach-grid button.is-selected {
  border-color: rgba(34,211,238,0.75);
  background: rgba(34,211,238,0.12);
  color: #f8fafc;
  box-shadow: inset 0 0 0 1px rgba(34,211,238,0.25);
}

.command-meter-stack {
  display: grid;
  gap: 0.7rem;
}

.command-meter-row {
  display: grid;
  grid-template-columns: 5.4rem minmax(0, 1fr) 2.4rem;
  gap: 0.5rem;
  align-items: center;
}

.command-meter-row span {
  color: #cbd5e1;
  font-size: 0.72rem;
}

.command-meter-row b {
  height: 0.35rem;
  overflow: hidden;
  background: rgba(51,65,85,0.72);
}

.command-meter-row i {
  display: block;
  height: 100%;
  background: #22d3ee;
}

.command-meter-row.is-risk i {
  background: #f59e0b;
}

.command-meter-row strong {
  color: #f8fafc;
  font-size: 0.72rem;
  text-align: right;
}

.command-scout-response {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  gap: 0.5rem;
  align-items: center;
  border: 1px solid rgba(245,158,11,0.28);
  background: rgba(245,158,11,0.08);
  padding: 0.52rem 0.58rem;
}

.command-scout-response span {
  color: #94a3b8;
  font-size: 0.66rem;
}

.command-scout-response strong {
  color: #fde68a;
  font-size: 0.78rem;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.command-decision-card {
  display: grid;
  gap: 0.25rem;
}

.command-decision-card div {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 0.5rem;
  border-top: 1px solid rgba(30,41,59,0.75);
  padding-top: 0.25rem;
}

.command-decision-card div:first-child {
  border-top: 0;
  padding-top: 0;
}

.command-decision-card span {
  color: #94a3b8;
  font-size: 0.68rem;
}

.command-decision-card strong {
  color: #f8fafc;
  font-size: 0.76rem;
  text-align: right;
}

.command-decision-card strong.is-warning {
  color: #f59e0b;
}

.command-decision-card strong.is-ready {
  color: #10b981;
}

.command-primary-lock {
  width: 100%;
  margin-top: 0.55rem;
  border: 0;
  background: #22d3ee;
  color: #020617;
  cursor: pointer;
  font-family: var(--font-display);
  font-size: 0.82rem;
  font-weight: 900;
  letter-spacing: 0.14em;
  padding: 0.7rem 0.8rem;
  text-transform: uppercase;
}

.command-primary-lock:disabled {
  background: #1e293b;
  color: #64748b;
  cursor: not-allowed;
}

.command-secondary-rail {
  display: flex;
  flex-direction: column;
  min-height: 0;
  margin-top: 0.4rem;
  overflow: hidden;
  border: 1px solid #334155;
  border-radius: 6px;
  background: rgba(15,23,42,0.85);
  box-shadow: 0 -2px 12px rgba(2,6,23,0.45);
}

.command-plan-subtitle {
  margin: 0.35rem 0 0;
  color: #94a3b8;
  font-size: 0.78rem;
  line-height: 1.4;
  max-width: 38rem;
}

.command-policy-summary {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.35rem 0.85rem;
  margin-top: 0.55rem;
}

.command-policy-summary > div {
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
  min-width: 0;
  border-top: 1px solid rgba(30,41,59,0.85);
  padding-top: 0.3rem;
}

.command-policy-summary > div:nth-child(-n+2) {
  border-top: 0;
  padding-top: 0;
}

.command-policy-summary > div:last-child:nth-child(odd) {
  grid-column: 1 / -1;
}

.command-policy-summary span {
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-policy-summary strong {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.78rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.command-policy-edit-trigger {
  align-self: flex-start;
  margin-top: 0.7rem;
  border: 1px solid rgba(34,211,238,0.4);
  border-radius: 4px;
  background: rgba(34,211,238,0.08);
  color: #22d3ee;
  cursor: pointer;
  font-family: var(--font-display);
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  padding: 0.45rem 0.75rem;
  text-transform: uppercase;
}

.command-policy-edit-trigger:hover {
  background: rgba(34,211,238,0.15);
}

.command-policy-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(2,6,23,0.75);
  padding: 1.5rem;
}

.command-policy-overlay-body {
  position: relative;
  width: min(100%, 38rem);
  max-height: calc(100vh - 4rem);
  overflow-y: auto;
  border: 1px solid #334155;
  border-radius: 8px;
  background: #0a1220;
  box-shadow: 0 30px 60px rgba(0,0,0,0.55);
  padding: 1.25rem 1.25rem 1rem;
}

.command-policy-overlay-close {
  position: absolute;
  top: 0.65rem;
  right: 0.65rem;
  border: 1px solid #334155;
  border-radius: 4px;
  background: transparent;
  color: #cbd5e1;
  cursor: pointer;
  font-family: var(--font-display);
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  padding: 0.35rem 0.6rem;
  text-transform: uppercase;
  z-index: 1;
}

.command-policy-overlay-close:hover {
  background: rgba(148,163,184,0.1);
  color: #f8fafc;
}

.command-secondary-tabs {
  display: flex;
  gap: 0.35rem;
  border-bottom: 1px solid rgba(30,41,59,0.95);
  padding: 0.45rem;
}

.command-secondary-tabs button {
  border: 1px solid rgba(51,65,85,0.74);
  background: transparent;
  color: #94a3b8;
  cursor: pointer;
  font-size: 0.68rem;
  font-weight: 800;
  padding: 0.35rem 0.55rem;
}

.command-secondary-tabs button.is-active {
  border-color: rgba(34,211,238,0.5);
  background: rgba(34,211,238,0.12);
  color: #22d3ee;
}

.command-secondary-body {
  flex: 1;
  min-height: 0;
  overflow: auto;
  padding: 0.75rem 1rem;
}

.command-strip-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}

.command-strip-meta span:nth-child(3),
.command-strip-meta span:nth-child(4) {
  color: #f8fafc;
}

.command-overview-grid {
  display: grid;
  grid-template-columns: minmax(18rem, 1.15fr) minmax(18rem, 1.1fr) minmax(16rem, 0.85fr);
  gap: 0.8rem;
}

.command-overview-card {
  display: grid;
  gap: 0.8rem;
  padding: 1rem;
  min-height: 10.3rem;
}

.command-overview-heading {
  display: grid;
  gap: 0.25rem;
}

.command-overview-heading .dm-kicker {
  margin: 0;
}

.command-overview-heading strong {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 1.2rem;
  line-height: 1;
  text-transform: uppercase;
}

.command-overview-copy {
  margin: 0;
  color: #cbd5e1;
  font-size: 0.84rem;
  line-height: 1.45;
}

.command-overview-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}

.command-strip-meta span,
.command-overview-meta span {
  border: 1px solid rgba(51, 65, 85, 0.78);
  background: rgba(15, 23, 42, 0.76);
  color: #cbd5e1;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  padding: 0.32rem 0.48rem;
  text-transform: uppercase;
}

.command-overview-callout {
  border-left: 3px solid #10b981;
  background: rgba(16, 185, 129, 0.08);
  color: #d1fae5;
  font-size: 0.76rem;
  line-height: 1.35;
  padding: 0.55rem 0.65rem;
}

.command-overview-callout.is-warning {
  border-left-color: #f59e0b;
  background: rgba(245, 158, 11, 0.08);
  color: #fde68a;
}

.command-threat-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  align-items: center;
}

.command-threat-summary b,
.command-threat-summary span {
  border: 1px solid rgba(51, 65, 85, 0.78);
  background: rgba(15, 23, 42, 0.76);
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  padding: 0.32rem 0.48rem;
  text-transform: uppercase;
}

.command-threat-summary b {
  color: #f87171;
}

.command-threat-summary span {
  color: #cbd5e1;
}

.command-threat-summary .is-fit {
  border-color: rgba(16, 185, 129, 0.28);
  background: rgba(16, 185, 129, 0.08);
  color: #10b981;
}

.command-threat-summary .is-danger {
  border-color: rgba(248, 113, 113, 0.28);
  background: rgba(248, 113, 113, 0.08);
  color: #f87171;
}

.command-decision-stack {
  display: grid;
  gap: 0.55rem;
}

.command-decision-stack div {
  border-top: 1px solid rgba(30, 41, 59, 0.75);
  padding-top: 0.55rem;
}

.command-decision-stack div:first-child {
  border-top: 0;
  padding-top: 0;
}

.command-decision-stack span {
  display: block;
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-decision-stack strong {
  display: block;
  margin-top: 0.22rem;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.95rem;
  text-transform: uppercase;
}

.command-detail-heading {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: center;
  margin-top: 0.35rem;
  color: #64748b;
}

.command-detail-heading .dm-kicker {
  margin: 0;
}

.command-detail-heading span {
  color: #64748b;
  font-size: 0.76rem;
}

.command-last-match {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  border: 1px solid #1e293b;
  background: #0a1628;
  color: #64748b;
  font-family: var(--font-display);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  padding: 0.75rem 1rem;
  text-transform: uppercase;
}

.command-last-match .is-win {
  color: #10b981;
  font-weight: 700;
}

.command-last-match .is-loss {
  color: #f43f5e;
  font-weight: 700;
}

.command-last-match .is-draw {
  color: #94a3b8;
  font-weight: 700;
}

.command-detail-panel {
  min-width: 0;
}

.command-detail-panel summary {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: center;
  cursor: pointer;
  list-style: none;
  padding: 0.9rem 1rem;
}

.command-detail-panel summary::-webkit-details-marker {
  display: none;
}

.command-detail-panel summary span {
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.command-detail-panel summary strong {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.95rem;
  text-transform: uppercase;
}

.command-detail-panel summary::after {
  color: #64748b;
  content: '›';
  font-family: var(--font-display);
  font-size: 1rem;
}

.command-detail-panel[open] summary {
  border-bottom: 1px solid rgba(30, 41, 59, 0.9);
}

.command-detail-panel[open] summary::after {
  content: '⌄';
}

.command-detail-body {
  padding: 0.8rem;
}

.command-strip-actions {
  display: grid;
  grid-template-columns: auto minmax(12rem, 1fr);
  gap: 0.55rem;
  align-items: center;
}

.command-strip-actions p {
  grid-column: 1 / -1;
  margin: 0;
  color: #94a3b8;
  font-size: 0.68rem;
  line-height: 1.3;
}

.command-strip-status {
  display: grid;
  gap: 0.15rem;
}

.command-strip-status span {
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.command-strip-status strong {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.95rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.command-strip-button {
  display: flex;
  min-height: 2.35rem;
  min-width: 15rem;
  align-items: center;
  justify-content: space-between;
  gap: 0.8rem;
  border: 0;
  background: #f8fafc;
  color: #020617;
  cursor: pointer;
  font-family: var(--font-display);
  font-size: 0.82rem;
  font-weight: 900;
  letter-spacing: 0.16em;
  padding: 0.5rem 0.8rem;
  text-transform: uppercase;
}

.command-strip-button b {
  display: grid;
  width: 1.6rem;
  height: 1.6rem;
  place-items: center;
  border: 1px solid rgba(2, 6, 23, 0.28);
  border-radius: 999px;
  font-size: 0.9rem;
}

.command-strip-button:disabled {
  background: #1e293b;
  color: #64748b;
  cursor: not-allowed;
}

.command-matchup-brief {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(30, 41, 59, 0.95);
  background: rgba(2, 6, 23, 0.88);
}

.command-matchup-glow {
  position: absolute;
  inset-block: -35%;
  width: 36%;
  border-radius: 999px;
  filter: blur(52px);
  opacity: 0.9;
  pointer-events: none;
}

.command-matchup-glow-away {
  left: -6%;
  background: rgba(34, 211, 238, 0.15);
}

.command-matchup-glow-home {
  right: -6%;
  background: rgba(249, 115, 22, 0.15);
}

.command-matchup-brief-inner {
  position: relative;
  display: grid;
  gap: 0.38rem;
  padding: 0.7rem 0.95rem 0.78rem;
}

.command-matchup-row {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto minmax(0, 1fr) auto;
  gap: 0.9rem;
  align-items: center;
}

.command-team-sigil {
  display: grid;
  width: clamp(3.2rem, 5vw, 4.8rem);
  height: clamp(3.2rem, 5vw, 4.8rem);
  place-items: center;
  border-radius: 999px;
  font-size: clamp(1.4rem, 2.4vw, 2.2rem);
}

.command-team-sigil.is-away {
  color: #38bdf8;
  background: radial-gradient(circle, rgba(34, 211, 238, 0.22), rgba(2, 6, 23, 0));
}

.command-team-sigil.is-home {
  color: #fb923c;
  background: radial-gradient(circle, rgba(249, 115, 22, 0.24), rgba(2, 6, 23, 0));
}

.command-matchup-context {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.64rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.command-matchup-copy p {
  margin: 0;
  color: #cbd5e1;
  font-size: 0.76rem;
}

.command-matchup-team {
  min-width: 0;
}

.command-matchup-team small {
  display: block;
  margin-bottom: 0.18rem;
  color: #94a3b8;
  font-family: var(--font-mono-data);
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.command-matchup-team strong {
  display: block;
  overflow: hidden;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: clamp(1.2rem, 1.85vw, 1.7rem);
  line-height: 0.95;
  text-overflow: ellipsis;
  text-transform: uppercase;
  white-space: nowrap;
}

.command-matchup-team span {
  display: block;
  margin-top: 0.25rem;
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.command-matchup-team.is-away {
  text-align: right;
}

.command-matchup-team.is-home {
  text-align: left;
}

.command-matchup-vs {
  display: grid;
  width: 2.35rem;
  height: 2.35rem;
  place-items: center;
  border: 1px solid rgba(30, 41, 59, 0.9);
  border-radius: 999px;
  background: rgba(2, 6, 23, 0.86);
  color: #64748b;
  font-family: var(--font-display);
  font-size: 0.78rem;
  font-style: italic;
}

.command-matchup-share {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 0.75rem;
  align-items: center;
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-matchup-share > div {
  display: flex;
  gap: 0.35rem;
  align-items: center;
}

.command-matchup-share > div:last-child {
  justify-content: flex-end;
}

.command-matchup-share strong {
  color: #f8fafc;
}

.command-matchup-share em {
  font-style: normal;
}

.command-matchup-bar {
  display: flex;
  height: 0.42rem;
  overflow: hidden;
  border: 1px solid rgba(30, 41, 59, 0.95);
  background: #020617;
}

.command-matchup-bar .is-away {
  background: linear-gradient(90deg, #0e7490, #22d3ee);
}

.command-matchup-bar .is-home {
  background: linear-gradient(270deg, #c2410c, #fb923c);
}

.command-dashboard-header {
  display: flex;
  justify-content: space-between;
  gap: 1.25rem;
  align-items: flex-start;
  border-bottom: 1px solid #1e293b;
  padding-bottom: 0.85rem;
}

.command-dashboard-header h1 {
  margin: 0 0 0.25rem;
  color: #fff;
  font-family: var(--font-display);
  font-size: clamp(1.85rem, 3.2vw, 2.35rem);
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1;
  text-transform: uppercase;
}

.command-dashboard-subtitle {
  color: #22d3ee;
  font-size: clamp(1.05rem, 1.8vw, 1.35rem);
  font-weight: 800;
  text-transform: uppercase;
}

.command-dashboard-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(7rem, auto));
  gap: 1.5rem;
  text-align: right;
}

.command-dashboard-metrics span,
.command-panel-heading > span,
.command-current-plan span,
.command-orders-grid span,
.command-stat-list span,
.command-week-timeline span {
  display: block;
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.68rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.command-dashboard-metrics strong {
  display: block;
  margin-top: 0.3rem;
  color: #f8fafc;
  font-size: 1.35rem;
}

.command-dashboard-metrics small {
  color: #64748b;
  font-size: 0.8rem;
}

.command-next-action {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: flex-start;
  padding: 1rem 1.15rem;
  border-color: rgba(34, 211, 238, 0.22);
  background:
    linear-gradient(90deg, rgba(34, 211, 238, 0.08), transparent 55%),
    rgba(15, 23, 42, 0.86);
}

.command-next-action-copy {
  display: grid;
  gap: 0.45rem;
}

.command-next-action-step {
  display: inline-flex;
  width: fit-content;
  align-items: center;
  border: 1px solid rgba(34, 211, 238, 0.28);
  background: rgba(2, 6, 23, 0.48);
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.66rem;
  font-weight: 800;
  letter-spacing: 0.14em;
  padding: 0.25rem 0.45rem;
  text-transform: uppercase;
}

.command-next-action h2 {
  margin: 0;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 1.1rem;
  text-transform: uppercase;
}

.command-next-action p {
  margin: 0.25rem 0 0;
  color: #cbd5e1;
  font-size: 0.88rem;
  line-height: 1.45;
}

.command-next-action-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: flex-end;
}

.command-next-action-buttons .command-primary-button,
.command-next-action-buttons .command-secondary-button {
  width: auto;
  margin-top: 0;
}

.command-alert-strip {
  display: grid;
  grid-template-columns: minmax(7rem, auto) repeat(3, minmax(0, 1fr));
  gap: 0.7rem;
  align-items: stretch;
}

.command-alert-strip > div {
  display: flex;
  align-items: center;
  color: #f59e0b;
  font-size: 0.75rem;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.command-alert-strip article {
  min-width: 0;
  border: 1px solid rgba(34,211,238,0.24);
  border-left: 3px solid #22d3ee;
  background: rgba(15,23,42,0.72);
  padding: 0.65rem 0.85rem;
}

.command-alert-strip article:first-of-type {
  border-color: rgba(245,158,11,0.32);
  border-left-color: #f59e0b;
}

.command-alert-strip strong,
.command-fit-note strong {
  color: #f8fafc;
  font-size: 0.82rem;
}

.command-alert-strip span {
  display: block;
  margin-top: 0.25rem;
  color: #cbd5e1;
  font-size: 0.78rem;
  line-height: 1.3;
}

.command-dashboard-main {
  display: grid;
  grid-template-columns: repeat(3, minmax(18.5rem, 1fr));
  gap: 0.8rem;
  align-items: start;
}

.command-secondary-grid > .dm-panel {
  padding: clamp(0.85rem, 1.5vw, 1.15rem);
}

.command-game-plan {
  display: flex;
  flex-direction: column;
}

.command-game-plan .command-panel-heading {
  align-items: stretch;
}

.command-game-plan .command-current-plan {
  width: min(100%, 15rem);
}

.command-game-plan .command-order-pills {
  margin-top: 0.65rem;
}

.command-control-tower {
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.command-control-tower > .command-panel-heading {
  margin-bottom: 0.45rem;
}

.command-panel-heading {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: flex-start;
  margin-bottom: 0.75rem;
}

.command-panel-heading .dm-kicker {
  margin: 0;
}

.command-panel-heading h3,
.command-game-plan h3 {
  margin: 0.25rem 0 0;
  color: #fff;
  font-size: 1.18rem;
  text-transform: uppercase;
}

.command-cockpit-panel h3 {
  font-size: 1.55rem;
}

.command-opponent-file h2 {
  margin: 0 0 0.65rem;
  color: #fff;
  font-size: clamp(1.5rem, 3vw, 2rem);
  line-height: 1;
  text-transform: uppercase;
}

.command-opponent-meta {
  display: flex;
  gap: 0.75rem;
  align-items: center;
  margin-bottom: 1rem;
}

.command-opponent-meta > span {
  border-radius: 4px;
  background: rgba(244,63,94,0.14);
  color: #fb7185;
  font-weight: 900;
  padding: 0.25rem 0.5rem;
}

.command-opponent-meta em {
  color: #cbd5e1;
  font-size: 0.85rem;
}

.command-verdict {
  margin-bottom: 1rem;
  border-left: 3px solid #f59e0b;
  background: rgba(245,158,11,0.12);
  color: #f8fafc;
  font-weight: 800;
  line-height: 1.35;
  padding: 0.85rem 1rem;
}

.command-verdict-compact {
  margin: 0.65rem 0 0;
  padding: 0.65rem 0.8rem;
  font-size: 0.82rem;
}

.command-two-column {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.85rem;
}

.command-two-column > div {
  border: 1px solid rgba(51,65,85,0.8);
  background: rgba(2,6,23,0.24);
  padding: 0.8rem;
}

.command-two-column ul,
.command-impact-list,
.command-readiness-list,
.command-player-list,
.command-stat-list,
.command-week-timeline {
  display: grid;
  gap: 0.65rem;
  margin: 0;
  padding: 0;
}

.command-two-column li {
  list-style: none;
  color: #cbd5e1;
  font-size: 0.8rem;
  line-height: 1.35;
}

.command-two-column li span {
  display: block;
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-muted-copy {
  margin: 0.6rem 0 0;
  color: #94a3b8;
  font-size: 0.82rem;
  line-height: 1.45;
}

.command-secondary-link,
.command-secondary-button {
  display: inline-flex;
  justify-content: center;
  margin-top: 1rem;
  border: 1px solid #334155;
  border-radius: 4px;
  background: transparent;
  color: #cbd5e1;
  cursor: pointer;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  padding: 0.7rem 0.85rem;
  text-decoration: none;
  text-transform: uppercase;
}

.command-current-plan {
  width: min(100%, 23rem);
  border: 1px solid #1e293b;
  background: #020617;
  padding: 0.55rem 0.7rem;
}

.command-current-plan strong {
  display: block;
  margin-top: 0.25rem;
  color: #22d3ee;
  font-family: var(--font-display);
  font-size: 1.15rem;
  line-height: 1;
  text-transform: uppercase;
}

.command-current-plan p {
  margin: 0.25rem 0 0;
  color: #94a3b8;
  display: -webkit-box;
  overflow: hidden;
  font-size: 0.7rem;
  line-height: 1.25;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.command-plan-grid {
  display: grid;
  grid-template-columns: minmax(14rem, 0.72fr) minmax(17rem, 1fr);
  gap: 0.8rem;
}

.command-order-pills {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.55rem;
  margin-top: 0.65rem;
}

.command-order-pills div,
.command-intel-summary-grid div {
  border: 1px solid rgba(51,65,85,0.74);
  background: rgba(2,6,23,0.28);
  min-width: 0;
  padding: 0.52rem 0.58rem;
}

.command-order-pills span,
.command-intel-meta span,
.command-intel-summary-grid span {
  display: block;
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-order-pills strong,
.command-intel-summary-grid strong {
  display: block;
  margin-top: 0.25rem;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.78rem;
  line-height: 1.25;
  text-transform: uppercase;
}

.command-intel-summary-grid strong {
  display: block;
  overflow: visible;
  word-break: break-word;
}

.command-plan-alert {
  display: flex;
  gap: 0.55rem;
  margin-top: 0.65rem;
  border-left: 3px solid #10b981;
  background: rgba(16,185,129,0.08);
  padding: 0.5rem 0.58rem;
}

.command-plan-alert.is-warning {
  border-left-color: #f59e0b;
  background: rgba(245,158,11,0.08);
}

.command-plan-alert strong {
  color: #f8fafc;
  font-size: 0.74rem;
  line-height: 1.35;
}

.command-plan-alert span {
  width: fit-content;
  border: 1px solid rgba(16, 185, 129, 0.28);
  background: rgba(16, 185, 129, 0.08);
  color: #10b981;
  font-family: var(--font-mono-data);
  font-size: 0.6rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  padding: 0.22rem 0.36rem;
  text-transform: uppercase;
}

.command-plan-alert.is-warning span {
  border-color: rgba(245, 158, 11, 0.28);
  background: rgba(245, 158, 11, 0.08);
  color: #f59e0b;
}

.command-orders-grid {
  grid-column: 1 / -1;
}

.command-field-label {
  margin: 0 0 0.55rem;
  color: #e2e8f0;
  font-size: 0.75rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-approach-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.45rem;
}

.command-approach-grid button {
  min-height: 3.15rem;
  border: 1px solid #334155;
  border-radius: 4px;
  background: transparent;
  color: #94a3b8;
  cursor: pointer;
  padding: 0.5rem 0.58rem;
  text-align: left;
}

.command-approach-grid button.is-selected {
  border: 2px solid #22d3ee;
  background: #0f172a;
  color: #fff;
}

.command-approach-grid button:disabled {
  cursor: default;
}

.command-approach-grid span {
  display: block;
  font-size: 0.82rem;
  font-weight: 900;
  text-transform: uppercase;
}

.command-approach-grid small {
  display: block;
  margin-top: 0.18rem;
  color: #94a3b8;
  font-size: 0.66rem;
  line-height: 1.28;
}

.command-impact-list {
  margin-top: 1rem;
}

.command-impact-list article,
.command-plan-summary,
.command-fit-note {
  border: 1px solid rgba(51,65,85,0.74);
  background: rgba(2,6,23,0.28);
  padding: 0.8rem;
}

.command-impact-list span {
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.command-impact-list strong {
  display: block;
  margin-top: 0.25rem;
  color: #f8fafc;
  font-size: 0.85rem;
  line-height: 1.35;
}

.command-priority-list {
  display: grid;
  gap: 0.55rem;
}

.command-tendency-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.55rem;
}

.command-tendency-card {
  border: 1px solid rgba(51,65,85,0.74);
  border-left: 3px solid #64748b;
  background: rgba(2,6,23,0.3);
  padding: 0.58rem 0.62rem;
}

.command-tendency-card span {
  display: block;
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-tendency-card strong {
  display: block;
  margin-top: 0.25rem;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 1rem;
  line-height: 1;
}

.command-tendency-card.is-pressure {
  border-left-color: #22d3ee;
}

.command-tendency-card.is-control {
  border-left-color: #10b981;
}

.command-tendency-card.is-risk {
  border-left-color: #f43f5e;
}

.command-tendency-card.is-tempo {
  border-left-color: #f59e0b;
}

.command-priority-list > div > div {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  color: #cbd5e1;
  font-size: 0.75rem;
  font-weight: 800;
}

.command-priority-list meter {
  display: block;
  width: 100%;
  height: 0.34rem;
  margin-top: 0.28rem;
}

.command-orders-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.5rem;
  margin-top: 0.1rem;
}

.command-orders-grid div {
  border: 1px solid rgba(51,65,85,0.74);
  background: rgba(2,6,23,0.3);
  padding: 0.55rem 0.65rem;
}

.command-orders-grid strong,
.command-plan-summary strong,
.command-stat-list strong,
.command-week-timeline strong {
  display: block;
  margin-top: 0.25rem;
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.82rem;
  text-transform: uppercase;
}

.command-readiness-list > div {
  display: grid;
  grid-template-columns: 1.75rem minmax(0, 1fr);
  gap: 0.65rem;
  align-items: center;
  border: 1px solid #334155;
  background: #1e293b;
  padding: 0.55rem 0.65rem;
}

.command-readiness-overview {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  border: 1px solid rgba(34,211,238,0.16);
  background: rgba(34,211,238,0.06);
  padding: 0.48rem 0.55rem;
}

.command-readiness-overview strong {
  color: #22d3ee;
  font-family: var(--font-display);
  font-size: 1.1rem;
}

.command-readiness-overview span {
  color: #94a3b8;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-readiness-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem;
  margin-top: 0.15rem;
}

.command-readiness-chips span {
  border: 1px solid rgba(51,65,85,0.74);
  background: rgba(15,23,42,0.88);
  color: #cbd5e1;
  font-size: 0.56rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  padding: 0.2rem 0.28rem;
  text-transform: uppercase;
}

.command-readiness-chips .is-ready {
  border-color: rgba(16,185,129,0.28);
  color: #10b981;
}

.command-readiness-chips .is-pending {
  border-color: rgba(245,158,11,0.28);
  color: #f59e0b;
}

.command-readiness-list > div > span {
  display: grid;
  width: 1.55rem;
  height: 1.55rem;
  place-items: center;
  border-radius: 999px;
  background: #334155;
  color: #94a3b8;
  font-size: 0.7rem;
  font-weight: 900;
}

.command-readiness-list .is-ready {
  border-color: rgba(16,185,129,0.28);
  background: rgba(16,185,129,0.06);
}

.command-readiness-list .is-ready > span {
  background: #10b981;
  color: #020617;
}

.command-readiness-list strong {
  color: #f8fafc;
  font-size: 0.78rem;
}

.command-readiness-list p {
  display: none;
  margin: 0.2rem 0 0;
  color: #94a3b8;
  font-size: 0.68rem;
  line-height: 1.25;
}

.command-plan-summary {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.28rem;
  margin-top: 0.45rem;
  border: 0;
  background: transparent;
  padding: 0;
}

.command-plan-summary div {
  border: 1px solid rgba(51,65,85,0.74);
  background: rgba(2,6,23,0.28);
  padding: 0.34rem 0.4rem;
}

.command-plan-summary strong {
  font-size: 0.64rem;
}

.command-lock-note {
  color: #f59e0b;
  font-size: 0.82rem;
  font-weight: 800;
  text-align: center;
}

.command-primary-button {
  width: 100%;
  margin-top: auto;
  border: 0;
  border-radius: 4px;
  background: #22d3ee;
  color: #020617;
  cursor: pointer;
  font-weight: 900;
  letter-spacing: 0.08em;
  padding: 0.78rem;
  text-transform: uppercase;
}

.command-primary-button:disabled {
  background: #1e293b;
  color: #64748b;
  cursor: not-allowed;
}

.command-primary-button.is-live {
  background: #10b981;
}

.command-secondary-grid {
  display: grid;
  grid-template-columns: minmax(18rem, 1fr) minmax(18rem, 1fr) minmax(15rem, 0.8fr);
  gap: 0.8rem;
  align-items: start;
}

.command-secondary-disclosure {
  border: 1px solid rgba(30, 41, 59, 0.95);
  background: rgba(15, 23, 42, 0.72);
}

.command-secondary-disclosure summary {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: center;
  cursor: pointer;
  list-style: none;
  padding: 0.9rem 1rem;
}

.command-secondary-disclosure summary::-webkit-details-marker {
  display: none;
}

.command-secondary-disclosure summary span {
  color: #22d3ee;
  font-family: var(--font-mono-data);
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.command-secondary-disclosure summary strong {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.95rem;
  text-transform: uppercase;
}

.command-secondary-disclosure summary::after {
  color: #64748b;
  content: '›';
  font-family: var(--font-display);
  font-size: 1rem;
}

.command-secondary-disclosure[open] summary {
  border-bottom: 1px solid rgba(30, 41, 59, 0.9);
}

.command-secondary-disclosure[open] summary::after {
  content: '⌄';
}

.command-secondary-disclosure[open] .command-secondary-grid {
  padding: 0.8rem;
}

.command-player-list div,
.command-stat-list div,
.command-week-timeline div {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto auto;
  gap: 0.5rem;
  align-items: center;
}

.command-player-list span {
  color: #64748b;
  font-size: 0.72rem;
}

.command-player-list strong {
  overflow: hidden;
  color: #f8fafc;
  font-size: 0.86rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.command-player-list small {
  color: #10b981;
  font-family: var(--font-mono-data);
  font-size: 0.72rem;
}

.command-stat-list div,
.command-week-timeline div {
  grid-template-columns: auto minmax(0, 1fr);
  border-top: 1px solid rgba(30,41,59,0.7);
  padding-top: 0.65rem;
}

.command-stat-list-compact {
  gap: 0.45rem;
}

.command-stat-list-compact div {
  padding-top: 0.45rem;
}

.command-fit-note {
  margin-top: 0.65rem;
  color: #cbd5e1;
  font-size: 0.78rem;
}

.command-fit-note.is-fit {
  border-left: 3px solid #10b981;
}

.command-fit-note.is-warning {
  border-left: 3px solid #f59e0b;
}

/* Opponent intel */
.command-threat-row {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  gap: 0.7rem;
  align-items: center;
  border: 1px solid rgba(51,65,85,0.74);
  border-left: 3px solid rgba(34,211,238,0.6);
  background: rgba(2,6,23,0.24);
  padding: 0.58rem 0.62rem;
  margin-bottom: 0.65rem;
}

.command-threat-row.is-disadvantage {
  border-left-color: rgba(245,158,11,0.85);
}

.command-threat-row > span {
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-threat-row > strong {
  color: #f8fafc;
  font-size: 0.88rem;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.command-threat-row > div {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  align-items: center;
  min-width: 0;
}

.command-threat-row em,
.command-threat-row b {
  border: 1px solid rgba(51,65,85,0.74);
  color: #cbd5e1;
  font-family: var(--font-mono-data);
  font-size: 0.6rem;
  font-style: normal;
  font-weight: 900;
  letter-spacing: 0.1em;
  padding: 0.22rem 0.34rem;
  text-transform: uppercase;
}

.command-intel-meta {
  display: flex;
  justify-content: space-between;
  gap: 0.75rem;
  align-items: center;
  margin-bottom: 0.65rem;
}

.command-intel-meta strong {
  color: #cbd5e1;
  font-size: 0.74rem;
}

.command-intel-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.45rem;
}

/* Week Timeline Pill Cards */
.command-week-pills {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0.5rem;
  margin-top: auto;
  padding-top: 0.95rem;
}

.command-week-pill {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  background: rgba(30,41,59,0.6);
  border-radius: 6px;
  padding: 0.7rem 0.75rem;
}

.command-week-pill.is-matchday {
  background: rgba(34,211,238,0.08);
  border: 1px solid rgba(34,211,238,0.25);
}

.command-week-pill-icon {
  font-size: 1rem;
  flex-shrink: 0;
}

.command-week-pill-label {
  display: block;
  color: #64748b;
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.command-week-pill.is-matchday .command-week-pill-label {
  color: #22d3ee;
}

.command-week-pill-value {
  display: block;
  color: #f8fafc;
  font-weight: 600;
  font-size: 0.74rem;
}

.command-opponent-file,
.command-dashboard-lower {
  margin-top: 0.15rem;
}

.command-scout-headline {
  display: flex;
  justify-content: space-between;
  gap: 0.8rem;
  align-items: baseline;
}

.command-scout-headline strong {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  line-height: 1;
  text-transform: uppercase;
}

.command-scout-headline span {
  border-radius: 4px;
  background: rgba(244,63,94,0.14);
  color: #fb7185;
  font-weight: 900;
  padding: 0.2rem 0.45rem;
}

.command-intel-card {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.command-intel-card .command-threat-row {
  margin-top: auto;
}

.command-control-squad {
  margin-top: 0.5rem;
  border-top: 1px solid rgba(30,41,59,0.75);
  padding-top: 0.5rem;
  min-height: 0;
  overflow: hidden;
}

.command-control-squad .command-panel-heading {
  margin-bottom: 0.5rem;
}

.command-control-squad .command-field-label {
  margin: 0;
}

.command-control-starters {
  display: grid;
  gap: 0;
}

.command-control-starters div {
  display: grid;
  grid-template-columns: 1rem minmax(0, 1fr) 2.15rem 4.2rem;
  gap: 0.6rem;
  align-items: baseline;
  border-top: 1px solid rgba(30,41,59,0.62);
  padding: 0.48rem 0;
}

.command-control-starters div:first-child {
  border-top: 0;
  padding-top: 0;
}

.command-control-starters span {
  color: #64748b;
  font-size: 0.68rem;
}

.command-control-starters strong {
  overflow: hidden;
  color: #f8fafc;
  font-size: 0.8rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.command-control-starters small {
  color: #10b981;
  font-family: var(--font-mono-data);
  font-size: 0.68rem;
  text-align: right;
}

.command-control-form {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.65rem;
  margin-top: 0.85rem;
}

.command-control-form div {
  border: 1px solid rgba(30,41,59,0.72);
  background: rgba(2,6,23,0.2);
  padding: 0.55rem 0.5rem;
}

.command-control-form strong,
.command-control-form span {
  display: block;
}

.command-control-form strong {
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.82rem;
  text-transform: uppercase;
}

.command-control-form span {
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.command-intel-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.75rem;
  align-items: start;
}

.command-inline-toggle {
  width: 100%;
  margin-top: 0.5rem;
  border: 1px solid rgba(51,65,85,0.74);
  background: transparent;
  color: #94a3b8;
  cursor: pointer;
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  padding: 0.38rem 0.45rem;
  text-transform: uppercase;
}

.command-inline-toggle:hover {
  border-color: rgba(34,211,238,0.38);
  color: #e2e8f0;
}

.command-league-row {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 0.7rem;
  align-items: center;
  padding: 0.7rem 1rem;
}

.command-league-row span {
  min-width: 0;
  color: #cbd5e1;
  font-size: 0.8rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.command-league-row span:last-child {
  text-align: right;
}

.command-league-row small {
  color: #475569;
  font-family: var(--font-mono-data);
  font-size: 0.7rem;
}

.command-empty-state {
  color: #64748b;
  font-size: 0.78rem;
  padding: 0.85rem 1rem;
}

.command-week-timeline-inline {
  grid-template-columns: 1fr;
  margin-top: auto;
  padding-top: 0.95rem;
}

.command-week-timeline-inline div {
  grid-template-columns: minmax(0, auto) minmax(0, 1fr);
}

/* === DYNASTY OFFICE === */
.dynasty-recruit-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(18rem, 22rem);
  grid-template-areas:
    "main credibility"
    "main staff";
  gap: 1.25rem;
  align-items: start;
}

.dynasty-recruit-main {
  grid-area: main;
  min-width: 0;
}

.dynasty-credibility-card {
  grid-area: credibility;
  min-width: 0;
  padding: 1rem;
}

.dynasty-staff-room {
  grid-area: staff;
  min-width: 0;
  padding: 1rem;
}

.dynasty-staff-row {
  display: grid;
  grid-template-columns: minmax(5.75rem, 0.85fr) minmax(0, 1fr);
  gap: 0.75rem;
  align-items: start;
  border-top: 1px solid rgba(30,41,59,0.7);
  margin-top: 0.85rem;
  padding-top: 0.85rem;
}

.dynasty-staff-row > div:last-child {
  grid-column: 2 / -1;
  min-width: 0;
  overflow-wrap: anywhere;
  white-space: normal;
  word-break: break-word;
}

.dynasty-slots-card {
  margin-bottom: 0.8rem;
  padding: 0.9rem 1rem;
}

.dynasty-slots-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.75rem;
}

/* === STANDINGS === */
.standings-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(17rem, 19rem);
  gap: 1.25rem;
  align-items: start;
}

.standings-table-panel {
  min-width: 0;
}

.standings-table-scroll {
  overflow-x: auto;
}

.standings-table-scroll .dm-table {
  table-layout: auto;
}

.standings-table-scroll .dm-table th,
.standings-table-scroll .dm-table td {
  padding: 0.7rem 0.6rem;
}

.playoff-bracket-panel {
  margin-bottom: 1.25rem;
  padding-bottom: 1rem;
}

.playoff-bracket-seeds {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  padding: 0 1rem 0.85rem;
}

.playoff-seed-chip {
  display: inline-flex;
  align-items: baseline;
  gap: 0.3rem;
  padding: 0.25rem 0.55rem;
  border: 1px solid rgba(51, 65, 85, 0.75);
  border-radius: 999px;
  background: rgba(2, 6, 23, 0.4);
  font-size: 0.72rem;
  color: #cbd5e1;
}

.playoff-seed-chip b {
  color: #22d3ee;
}

.playoff-seed-chip em {
  color: #64748b;
  font-style: normal;
  font-size: 0.66rem;
}

.playoff-seed-chip.is-user {
  border-color: #22d3ee;
  background: rgba(34, 211, 238, 0.1);
}

.playoff-bracket-grid {
  display: flex;
  gap: 1.5rem;
  padding: 0 1rem;
  align-items: stretch;
  flex-wrap: wrap;
}

.playoff-bracket-column {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  justify-content: center;
  min-width: 13rem;
}

.playoff-bracket-round-label {
  margin: 0;
  font-size: 0.6rem;
  color: #64748b;
}

.playoff-bracket-empty {
  font-size: 0.75rem;
  color: #475569;
  font-style: italic;
  margin: 0;
}

.playoff-champion-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15rem;
  padding: 0.85rem 1rem;
  border: 1px solid rgba(251, 191, 36, 0.5);
  border-radius: 6px;
  background: rgba(251, 191, 36, 0.08);
  text-align: center;
}

.playoff-champion-card strong {
  color: #fbbf24;
  font-size: 1rem;
}

.playoff-champion-card span {
  color: #94a3b8;
  font-size: 0.62rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.playoff-champion-trophy {
  font-size: 1.4rem;
}

.playoff-champion-card.is-user {
  border-color: #fbbf24;
  background: rgba(251, 191, 36, 0.14);
}

.command-strip-stage {
  color: #fbbf24;
  font-weight: 700;
  letter-spacing: 0.06em;
}

.standings-recent-card {
  min-width: 0;
}

.standings-desktop-view {
  display: block;
}

.standings-compact-view {
  display: none;
}

.standings-card-list {
  display: grid;
  gap: 0.75rem;
  padding: 0 1rem 1rem;
}

.standings-card {
  width: 100%;
  border: 1px solid rgba(51, 65, 85, 0.75);
  background: rgba(2, 6, 23, 0.32);
  color: #e2e8f0;
  padding: 0.95rem 1rem;
  text-align: left;
  cursor: pointer;
}

.standings-card.is-user-club {
  border-color: rgba(34, 211, 238, 0.45);
  box-shadow: inset 2px 0 0 #22d3ee;
}

.standings-card-header {
  display: flex;
  justify-content: space-between;
  gap: 0.75rem;
  align-items: flex-start;
}

.standings-card-header h3 {
  margin: 0.2rem 0 0;
  color: #fff;
  font-family: var(--font-display);
  font-size: 1rem;
  text-transform: uppercase;
}

.standings-card-points {
  text-align: right;
}

.standings-card-points span,
.standings-card-stats span {
  display: block;
  color: #64748b;
  font-family: var(--font-mono-data);
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.standings-card-points strong {
  display: block;
  margin-top: 0.25rem;
  color: #f8fafc;
  font-size: 1.15rem;
}

.standings-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 0.9rem;
  margin-top: 0.75rem;
  color: #cbd5e1;
  font-size: 0.8rem;
}

.standings-card-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.75rem;
  margin-top: 0.75rem;
  padding-top: 0.75rem;
  border-top: 1px solid rgba(30, 41, 59, 0.75);
}

.standings-card-stats strong {
  display: block;
  margin-top: 0.2rem;
  color: #f8fafc;
  font-size: 0.88rem;
}

@media (min-width: 1540px) {
  .command-dashboard-main {
    grid-template-columns: repeat(3, minmax(20rem, 1fr));
  }
}

@media (max-width: 1360px) {
  .standings-layout {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 1180px) {
  .dm-left-nav {
    width: 11rem;
  }

  .dm-nav-item {
    padding: 0.7rem 0.85rem;
    font-size: 0.76rem;
  }

  .dm-content {
    padding: 1.25rem;
  }

  .command-console-header {
    grid-template-columns: 1fr;
  }

  .command-cockpit-grid {
    grid-template-columns: 1fr;
  }

  .command-overview-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .command-overview-card:last-child {
    grid-column: 1 / -1;
  }

  .command-dashboard-main {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .command-control-tower {
    grid-column: 1 / -1;
  }

  .command-secondary-grid,
  .command-plan-grid,
  .command-squad-grid,
  .command-intel-grid {
    grid-template-columns: 1fr;
  }

  .command-alert-strip {
    grid-template-columns: 1fr;
  }

  .command-dashboard-metrics {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    text-align: left;
  }

  .dynasty-recruit-layout {
    grid-template-columns: minmax(0, 1fr);
    grid-template-areas:
      "credibility"
      "main"
      "staff";
  }

  .dynasty-staff-room {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem 1rem;
  }

  .dynasty-staff-room > .dm-kicker,
  .dynasty-staff-room > button {
    grid-column: 1 / -1;
  }

  .dynasty-staff-row {
    margin-top: 0;
  }

}

@media (max-width: 960px) {
  .dm-app-shell.flex {
    display: block !important;
  }

  .dm-left-nav {
    width: 100%;
    min-height: auto;
    border-right: 0;
    border-bottom: 1px solid #1e293b;
  }

  .dm-left-nav-logo,
  .dm-left-nav > div:last-child {
    padding: 0.65rem 0.9rem;
  }

  .dm-left-nav-logo {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .dm-left-nav nav[aria-label="Primary"] {
    display: flex !important;
    flex: none !important;
    flex-direction: row !important;
    align-items: stretch;
    gap: 0.35rem;
    overflow-x: auto;
    padding: 0 0.9rem 0.65rem !important;
    scrollbar-width: none;
  }

  .dm-left-nav nav[aria-label="Primary"]::-webkit-scrollbar {
    display: none;
  }

  .dm-left-nav > div:last-child {
    display: flex !important;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0 0.9rem 0.65rem !important;
    border-top: 0;
  }

  .dm-left-nav > div:last-child .dm-nav-item {
    display: none !important;
  }

  .dm-nav-item {
    width: auto;
    flex: 1 1 0;
    min-width: 0;
    min-height: 2.25rem;
    border-left: 0;
    border-bottom: 2px solid transparent;
    padding: 0.55rem 0.65rem;
    gap: 0.5rem;
    justify-content: center;
  }

  .dm-nav-item:hover,
  .dm-nav-item-active {
    border-left-color: transparent !important;
    border-bottom-color: #22d3ee !important;
  }

  .dm-nav-label-full {
    display: none;
  }

  .dm-nav-label-short {
    display: inline;
  }

  .dm-broadcast-header {
    position: static;
    padding: 0.75rem 0.9rem;
  }

  .dm-workspace {
    min-height: auto;
  }

  .dm-content {
    padding: 0.95rem;
  }

  .standings-desktop-view {
    display: none;
  }

  .standings-compact-view {
    display: block;
  }

  .command-next-action {
    flex-direction: column;
  }

  .command-next-action-buttons {
    width: 100%;
    justify-content: flex-start;
  }

  .command-next-action-buttons .command-primary-button,
  .command-next-action-buttons .command-secondary-button {
    width: 100%;
    margin-top: 0;
  }

  .command-dashboard-main {
    grid-template-columns: 1fr;
  }

  .command-control-tower {
    grid-column: auto;
  }

  .command-overview-grid {
    grid-template-columns: 1fr;
  }

  .command-overview-card:last-child {
    grid-column: auto;
  }
}

@media (max-width: 720px) {
  .dm-app-shell.flex {
    display: block !important;
  }

  .dm-left-nav-logo {
    padding-bottom: 0.55rem;
  }

  .command-dashboard-header {
    flex-direction: column;
  }

  .command-dashboard-metrics,
  .command-two-column,
  .command-order-pills,
  .command-approach-grid,
  .command-orders-grid,
  .command-plan-summary,
  .command-tendency-grid,
  .command-intel-summary-grid,
  .command-week-timeline-inline {
    grid-template-columns: 1fr;
  }

  .command-strip-actions,
  .command-detail-heading,
  .command-panel-heading,
  .command-opponent-meta,
  .command-plan-summary div {
    align-items: flex-start;
    flex-direction: column;
  }

  .command-strip-meta {
    justify-content: flex-start;
  }

  .command-strip-actions {
    display: flex;
  }

  .command-strip-button {
    width: 100%;
  }

  .command-plan-grid {
    grid-template-columns: 1fr;
  }

  .command-scout-response {
    grid-template-columns: 1fr;
  }

  .command-threat-row {
    grid-template-columns: 1fr;
  }

  .command-matchup-row,
  .command-matchup-share {
    grid-template-columns: 1fr;
  }

  .command-team-sigil {
    margin: 0 auto;
  }

  .command-matchup-team.is-away,
  .command-matchup-team.is-home,
  .command-matchup-share > div:last-child {
    justify-content: center;
    text-align: center;
  }

  .command-matchup-share > div {
    justify-content: center;
  }

  .command-matchup-vs {
    margin: 0 auto;
  }

  .command-readiness-list p {
    display: block;
  }

  .command-current-plan {
    max-width: none;
    width: 100%;
  }

  .dynasty-slots-grid,
  .dynasty-staff-room {
    grid-template-columns: 1fr;
  }

  .dynasty-staff-row {
    grid-template-columns: 1fr;
    gap: 0.35rem;
  }

  .dynasty-staff-row > div:last-child {
    grid-column: auto;
  }

  .dm-replay-controls {
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
  }

  .standings-card-meta,
  .standings-card-stats {
    grid-template-columns: 1fr;
  }

  .standings-card-meta {
    flex-direction: column;
    gap: 0.35rem;
  }
}

/* === MOTION === */
@keyframes dm-pulse-orange {
  0%, 100% { box-shadow: 0 0 18px rgba(249,115,22,0.28); }
  50% { box-shadow: 0 0 32px rgba(249,115,22,0.50); }
}

@keyframes dm-pulse-cyan {
  0%, 100% { box-shadow: 0 0 18px rgba(6,182,212,0.28); }
  50% { box-shadow: 0 0 32px rgba(6,182,212,0.50); }
}

@keyframes dm-flash-rose {
  0% { background: rgba(244,63,94,0.20); }
  100% { background: transparent; }
}

.dm-animate-pulse-orange {
  animation: dm-pulse-orange 2s ease-in-out infinite;
}

.dm-animate-flash-rose {
  animation: dm-flash-rose 280ms ease-out forwards;
}

/* Score change highlight */
@keyframes dm-score-bump {
  0% { transform: scale(1.0); color: #f97316; }
  40% { transform: scale(1.12); color: #fff; }
  100% { transform: scale(1.0); color: #f97316; }
}

.dm-animate-score-bump {
  animation: dm-score-bump 400ms ease-out forwards;
}

/* Button press feel */
.dm-btn-press:active {
  transform: scale(0.98);
}

/* Row reveal */
@keyframes dm-row-reveal {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}

.dm-animate-row-reveal {
  animation: dm-row-reveal 180ms ease-out forwards;
}

/* === EMPTY STATES === */
.dm-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 3rem 1.5rem;
  text-align: center;
  color: #475569;
}

.dm-empty-state-icon {
  font-size: 2rem;
  margin-bottom: 0.75rem;
  opacity: 0.4;
}

.dm-empty-state-title {
  font-family: var(--font-display);
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #64748b;
  margin: 0 0 0.25rem;
}

.dm-empty-state-body {
  font-size: 0.875rem;
  color: #475569;
  margin: 0;
}

/* === LOADING / SKELETON === */
@keyframes dm-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.dm-skeleton {
  background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);
  background-size: 200% 100%;
  animation: dm-shimmer 1.5s ease-in-out infinite;
  border-radius: 2px;
}

.dm-skeleton-text {
  height: 0.875rem;
  border-radius: 2px;
}

.dm-skeleton-line {
  height: 1px;
  border-radius: 0;
}

/* Sim Transition Animations */
.match-week-shell {
  position: relative;
}

.dm-transition-overlay {
  position: absolute;
  inset: 0;
  z-index: 5;
  min-height: 18rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  background: color-mix(in srgb, #020617 80%, transparent);
  backdrop-filter: blur(2px);
}

.slide-up-out {
  animation: slideUpOut 0.3s ease-out forwards;
}

@keyframes slideUpOut {
  from { transform: translateY(0); opacity: 1; }
  to { transform: translateY(-20px); opacity: 0; }
}

.fade-in {
  animation: fadeIn 0.4s ease-out forwards;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.fade-out {
  animation: fadeOut 0.4s ease-out forwards;
}

@keyframes fadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

@media (prefers-reduced-motion: reduce) {
  .slide-up-out, .fade-in, .fade-out {
    animation: none !important;
  }
}

/* ============================================================
   COMMAND CENTER — polished pre-sim (design kit cc-* rules)
   Appended from ui-kit/styles.css — do not remove --dm-* :root
   aliases above or these rules will lose their token references.
   ============================================================ */

/* Utility wrapper used as the cc root container */
.cc-root {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
}

/* Small ghost button used inside panels */
.dm-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: 1px solid var(--dm-border-strong);
  border-radius: 4px;
  background: transparent;
  color: var(--dm-text-muted);
  font-family: var(--font-display);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 0.3rem 0.65rem;
  cursor: pointer;
  transition: border-color 140ms, color 140ms;
}
.dm-btn:hover { border-color: var(--dm-cyan); color: var(--dm-cyan-bright); }

/* Identity strip */
.cc-id-strip {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: rgba(15,23,42,0.65);
  overflow: hidden;
}
.cc-id-strip > div { padding: 0.85rem 1.1rem; border-left: 1px solid var(--dm-border); display: grid; gap: 4px; }
.cc-id-strip > div:first-child { border-left: 0; }
.cc-id-strip .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dm-text-dead); }
.cc-id-strip .val { font-family: var(--font-display); font-size: 0.95rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: #f1f5f9; line-height: 1.1; }
.cc-id-strip .val.cyan { color: var(--dm-cyan-bright); }
.cc-id-strip .val.orange { color: var(--dm-orange-hover); }
.cc-id-strip .val.num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }

/* Hero */
.cc-hero {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1.65fr) minmax(0, 1fr);
  gap: 0;
  border: 1px solid var(--dm-border);
  border-left: 2px solid var(--dm-orange);
  border-radius: var(--radius-md);
  background:
    radial-gradient(ellipse 60% 80% at 0% 100%, rgba(249,115,22,0.10), transparent 60%),
    linear-gradient(180deg, rgba(15,23,42,0.92), rgba(2,6,23,0.96)),
    #0f172a;
  overflow: hidden;
  box-shadow: 0 22px 60px rgba(0,0,0,0.32);
}
.cc-hero::before {
  content: ""; position: absolute; inset: 0;
  background-image: repeating-linear-gradient(180deg, rgba(34,211,238,0.025) 0 1px, transparent 1px 4px);
  pointer-events: none;
  mix-blend-mode: screen;
}
.cc-hero-left { padding: 1.75rem 1.85rem 1.5rem; display: grid; gap: 1.1rem; align-content: space-between; position: relative; z-index: 1; min-width: 0; }
.cc-hero-kick { display: flex; gap: 10px; align-items: center; font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--dm-cyan); flex-wrap: wrap; }
.cc-hero-kick .live-pip { width: 7px; height: 7px; border-radius: 999px; background: var(--dm-orange); box-shadow: 0 0 10px rgba(249,115,22,0.85); animation: cc-pulse 1.6s ease-in-out infinite; }
.cc-hero-kick .sep { width: 16px; height: 1px; background: var(--dm-cyan); opacity: 0.5; }
@keyframes cc-pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.85); } }

.cc-hero-headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: clamp(2rem, 3.8vw, 3.4rem);
  font-weight: 800;
  line-height: 1.02;
  letter-spacing: 0.005em;
  text-transform: uppercase;
  color: #f8fafc;
  max-width: 18ch;
  padding-bottom: 0.15em;
}
.cc-hero-headline .vs { color: var(--dm-text-muted); font-weight: 500; }
.cc-hero-headline .opp { background: linear-gradient(180deg, #f8fafc 0%, #cbd5e1 100%); -webkit-background-clip: text; background-clip: text; color: transparent; }

.cc-hero-frame {
  display: grid; gap: 6px;
  padding: 0.9rem 1rem;
  border-left: 2px solid var(--dm-orange);
  background: rgba(249,115,22,0.06);
  border-radius: 0 4px 4px 0;
}
.cc-hero-frame .line { font-size: 0.95rem; line-height: 1.55; color: var(--dm-text-secondary); }
.cc-hero-frame .line b { color: var(--dm-orange-hover); font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.18em; margin-right: 8px; font-weight: 800; }
.cc-hero-frame .line.watch b { color: var(--dm-cyan); }

.cc-hero-stats {
  display: grid; grid-template-columns: repeat(4, minmax(0,1fr));
  border-top: 1px solid var(--dm-border);
  margin: 0 -1.85rem -1.5rem;
}
.cc-hero-stats > div { padding: 0.95rem 1.1rem; border-left: 1px solid var(--dm-border); display: grid; gap: 4px; }
.cc-hero-stats > div:first-child { border-left: 0; }
.cc-hero-stats .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dm-text-dead); }
.cc-hero-stats .val { font-family: var(--font-display); font-size: 1rem; font-weight: 800; letter-spacing: 0.03em; text-transform: uppercase; color: #f1f5f9; line-height: 1.15; }

.cc-hero-right {
  position: relative; z-index: 1;
  border-left: 1px solid var(--dm-border);
  padding: 1.75rem 1.5rem 1.5rem;
  display: grid; gap: 1rem; align-content: start;
  background: radial-gradient(ellipse 80% 60% at 100% 0%, rgba(34,211,238,0.08), transparent 60%);
}

.cc-court-card {
  border: 1px solid var(--dm-border);
  border-radius: 6px;
  background: linear-gradient(180deg, rgba(2,6,23,0.5), rgba(15,23,42,0.4));
  padding: 0.9rem 1rem 0.7rem;
}
.cc-court-card .head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.4rem; }
.cc-court-card .head .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--dm-cyan); }
.cc-court-card .head .side { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.16em; color: var(--dm-orange-hover); text-transform: uppercase; }
.cc-court-svg { width: 100%; height: auto; display: block; }

.cc-threat-card-kit {
  border: 1px solid var(--dm-border-strong);
  border-left: 2px solid var(--dm-rose);
  border-radius: 4px;
  background: linear-gradient(180deg, rgba(244,63,94,0.06), rgba(2,6,23,0.4));
  padding: 0.85rem 1rem;
  display: grid; gap: 0.55rem;
}
.cc-threat-card-kit .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: #fb7185; }
.cc-threat-card-kit .name { font-family: var(--font-display); font-size: 1.35rem; font-weight: 800; letter-spacing: 0.02em; text-transform: uppercase; color: #fff; line-height: 1; }
.cc-threat-card-kit .row { display: flex; justify-content: space-between; align-items: center; font-family: var(--font-mono); font-size: 0.72rem; color: var(--dm-text-muted); letter-spacing: 0.06em; padding-top: 0.4rem; border-top: 1px solid rgba(244,63,94,0.18); }
.cc-threat-card-kit .row b { color: #f1f5f9; font-weight: 700; }
.cc-threat-card-kit .ovr { color: #fb7185; font-weight: 800; font-size: 1.05rem; font-family: var(--font-mono); }

/* Body grid — Plan / Scout / Lock */
.cc-body { display: grid; grid-template-columns: 1.35fr 1fr 0.95fr; gap: 1.1rem; align-items: stretch; }

.cc-panel {
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: var(--dm-surface-translucent);
  display: flex; flex-direction: column;
  overflow: hidden;
  transition: border-color 160ms ease;
}
.cc-panel:hover { border-color: var(--dm-border-strong); }
.cc-panel-head { padding: 1rem 1.25rem 0.9rem; border-bottom: 1px solid var(--dm-border); display: grid; gap: 6px; }
.cc-panel-head .kicker { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--dm-cyan); }
.cc-panel-head h2 { font-family: var(--font-display); font-size: 1.6rem; font-weight: 800; letter-spacing: 0.02em; text-transform: uppercase; color: #fff; margin: 0; line-height: 1; }
.cc-panel-head p { margin: 0.3rem 0 0; color: var(--dm-text-secondary); font-size: 0.88rem; line-height: 1.45; }
.cc-panel-body { padding: 1rem 1.25rem 1.25rem; display: grid; gap: 1rem; flex: 1; }

/* Plan panel */
.cc-align-callout {
  display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;
  padding: 0.75rem 0.9rem;
  border: 1px solid rgba(16,185,129,0.28);
  border-left: 2px solid var(--dm-emerald);
  border-radius: 4px;
  background: rgba(16,185,129,0.05);
}
.cc-align-callout.is-warning {
  border-color: rgba(245,158,11,0.28);
  border-left-color: var(--dm-amber);
  background: rgba(245,158,11,0.05);
}
.cc-align-callout .copy { color: #d1fae5; font-size: 0.85rem; line-height: 1.4; }
.cc-align-callout.is-warning .copy { color: #fde68a; }
.cc-align-callout .copy b { color: #fff; font-weight: 700; }
.cc-pill {
  font-family: var(--font-mono); font-size: 0.62rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase;
  padding: 4px 8px; border-radius: 3px;
  border: 1px solid var(--dm-border-strong); background: rgba(15,23,42,0.6); color: var(--dm-text-secondary);
}
.cc-pill.amber  { color: var(--dm-amber-bright); border-color: rgba(245,158,11,0.45); background: rgba(245,158,11,0.10); }
.cc-pill.cyan   { color: var(--dm-cyan-bright);  border-color: rgba(34,211,238,0.45); background: rgba(34,211,238,0.10); }
.cc-pill.emer   { color: var(--dm-emerald-bright); border-color: rgba(16,185,129,0.45); background: rgba(16,185,129,0.10); }
.cc-pill.rose   { color: #fb7185; border-color: rgba(244,63,94,0.45);  background: rgba(244,63,94,0.10); }

.cc-policy {
  display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 1px;
  background: var(--dm-border);
  border: 1px solid var(--dm-border);
  border-radius: 4px;
  overflow: hidden;
}
.cc-policy-cell {
  background: rgba(2,6,23,0.5);
  padding: 0.85rem 0.9rem;
  display: grid; gap: 6px;
  cursor: pointer; transition: background 140ms;
  position: relative;
}
.cc-policy-cell:hover { background: rgba(30,41,59,0.55); }
.cc-policy-cell .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dm-cyan); }
.cc-policy-cell .val { font-family: var(--font-display); font-size: 0.95rem; font-weight: 800; letter-spacing: 0.03em; text-transform: uppercase; color: #fff; line-height: 1.15; }
.cc-policy-cell .helper { font-size: 0.75rem; color: var(--dm-text-muted); line-height: 1.35; }
.cc-policy-cell::after {
  content: "▸"; position: absolute; top: 0.7rem; right: 0.7rem; color: var(--dm-text-dead); font-size: 0.7rem; transition: color 140ms, transform 140ms;
}
.cc-policy-cell:hover::after { color: var(--dm-cyan); transform: translateX(2px); }
.cc-policy-cell.ready  { border-left: 2px solid var(--dm-emerald); }
.cc-policy-cell.ready  .lbl { color: var(--dm-emerald-bright); }
.cc-policy-cell.pending { border-left: 2px solid var(--dm-amber); }
.cc-policy-cell.pending .lbl { color: var(--dm-amber-bright); }

.cc-plan-foot { display: flex; gap: 0.5rem; align-items: center; justify-content: space-between; margin-top: 0.2rem; }
.cc-plan-foot .note { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.14em; color: var(--dm-text-dead); text-transform: uppercase; }

/* Dev-focus select inside policy cell */
.cc-policy-cell select {
  background: rgba(2,6,23,0.7);
  border: 1px solid var(--dm-border-strong);
  border-radius: 3px;
  color: var(--dm-cyan-bright);
  font-family: var(--font-display);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding: 0.2rem 0.4rem;
  cursor: pointer;
  width: 100%;
}

/* Scout panel */
.cc-scout-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
  background: var(--dm-border);
  border: 1px solid var(--dm-border);
  border-radius: 4px;
  overflow: hidden;
}
.cc-scout-grid > div { background: rgba(2,6,23,0.5); padding: 0.8rem 0.9rem; display: grid; gap: 4px; }
.cc-scout-grid .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dm-cyan); }
.cc-scout-grid .val { font-family: var(--font-display); font-size: 0.85rem; font-weight: 700; color: #f1f5f9; letter-spacing: 0.04em; line-height: 1.3; text-transform: uppercase; }
.cc-scout-grid .val.mono { font-family: var(--font-mono); font-size: 0.78rem; font-variant-numeric: tabular-nums; letter-spacing: 0.02em; text-transform: none; color: #cbd5e1; }
.cc-scout-grid .span-2 { grid-column: span 2; }

.cc-scout-edge {
  display: grid; gap: 6px;
  padding: 0.95rem 1rem;
  border: 1px solid rgba(34,211,238,0.25);
  border-left: 2px solid var(--dm-cyan);
  border-radius: 4px;
  background: rgba(34,211,238,0.05);
}
.cc-scout-edge .row { display: flex; justify-content: space-between; align-items: baseline; }
.cc-scout-edge .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dm-cyan-bright); }
.cc-scout-edge .val { font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; color: #fff; letter-spacing: 0.02em; text-transform: uppercase; }
.cc-scout-edge .sub { font-size: 0.78rem; color: var(--dm-text-muted); line-height: 1.45; }

/* Lock panel */
.cc-lock {
  border-color: rgba(249,115,22,0.28);
  background:
    radial-gradient(ellipse 100% 50% at 50% 100%, rgba(249,115,22,0.10), transparent 70%),
    var(--dm-surface-translucent);
}
.cc-ready-row { display: grid; grid-template-columns: auto 1fr; gap: 10px; align-items: center; margin-top: 4px; }
.cc-ready-row .pulse-em { width: 10px; height: 10px; border-radius: 999px; background: var(--dm-emerald); box-shadow: 0 0 12px rgba(16,185,129,0.7); animation: cc-pulse 1.8s ease-in-out infinite; }
.cc-ready-row .lbl { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dm-emerald-bright); }

.cc-gates { display: grid; grid-template-columns: repeat(5, minmax(0,1fr)); gap: 5px; }
.cc-gate {
  display: grid; gap: 4px; justify-items: center;
  padding: 0.6rem 0.2rem;
  border-radius: 4px;
  text-align: center;
  font-family: var(--font-mono);
}
.cc-gate.ok    { border: 1px solid rgba(16,185,129,0.28); background: rgba(16,185,129,0.05); }
.cc-gate.ok .tick { color: var(--dm-emerald-bright); }
.cc-gate.ok .lbl  { color: var(--dm-emerald-bright); }
.cc-gate.pend  { border: 1px solid rgba(245,158,11,0.28); background: rgba(245,158,11,0.05); }
.cc-gate.pend .tick { color: var(--dm-amber-bright); }
.cc-gate.pend .lbl  { color: var(--dm-amber-bright); }
.cc-gate.opt   { border: 1px solid var(--dm-border-strong); background: rgba(2,6,23,0.45); }
.cc-gate.opt .tick { color: var(--dm-text-muted); }
.cc-gate.opt .lbl  { color: var(--dm-text-muted); }
.cc-gate .tick { font-size: 0.9rem; font-weight: 800; line-height: 1; }
.cc-gate .lbl  { font-size: 0.5rem; letter-spacing: 0.1em; text-transform: uppercase; }

.cc-intent-field { display: grid; gap: 0.4rem; }
.cc-intent-field .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dm-cyan); }
.cc-intent-field select {
  min-height: 2.5rem;
  border: 1px solid var(--dm-border-strong);
  border-radius: 4px;
  background: rgba(15,23,42,0.86);
  color: #f8fafc;
  font-family: var(--font-display);
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  padding: 0.5rem 0.75rem;
  text-transform: uppercase;
  cursor: pointer;
}

.cc-lock-readout { display: grid; border: 1px solid var(--dm-border); border-radius: 4px; overflow: hidden; }
.cc-lock-readout .lr {
  display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;
  padding: 0.6rem 0.9rem;
  border-top: 1px solid var(--dm-border);
  background: rgba(2,6,23,0.4);
}
.cc-lock-readout .lr:first-child { border-top: 0; }
.cc-lock-readout .lbl { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dm-text-muted); }
.cc-lock-readout .val { font-family: var(--font-display); font-size: 0.85rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #f1f5f9; }
.cc-lock-readout .val.em { color: var(--dm-emerald-bright); }
.cc-lock-readout .val.am { color: var(--dm-amber-bright); }
.cc-lock-readout .val.rose { color: #fb7185; }
.cc-lock-readout .val.mono { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }

.cc-lock-foot { display: grid; gap: 0.7rem; margin-top: auto; padding-top: 0.3rem; }
.cc-lock-foot .ctx { font-size: 0.82rem; color: var(--dm-text-muted); line-height: 1.45; text-align: center; padding: 0.4rem 0.5rem 0; }
.cc-lock-foot .ctx b { color: var(--dm-emerald-bright); font-weight: 600; }

.cc-btn-sim {
  display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 10px;
  width: 100%;
  padding: 1rem 1.2rem;
  border: 1px solid var(--dm-orange);
  border-radius: 6px;
  background: linear-gradient(180deg, var(--dm-orange) 0%, #ea580c 100%);
  color: #fff;
  font-family: var(--font-display); font-size: 1.05rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase;
  cursor: pointer;
  box-shadow: 0 0 0 1px rgba(249,115,22,0.18), 0 0 28px rgba(249,115,22,0.32), inset 0 1px 0 rgba(255,255,255,0.18);
  transition: transform 120ms ease, box-shadow 160ms ease, background 160ms ease;
  position: relative;
  overflow: hidden;
}
.cc-btn-sim:hover { transform: translateY(-1px); box-shadow: 0 0 0 1px rgba(249,115,22,0.28), 0 0 36px rgba(249,115,22,0.5), inset 0 1px 0 rgba(255,255,255,0.22); }
.cc-btn-sim:focus-visible { outline: 2px solid rgba(34, 211, 238, 0.9); outline-offset: 2px; }
.cc-btn-sim:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }
.cc-btn-sim .arrow { font-family: var(--font-mono); font-size: 1.1rem; font-weight: 800; }
.cc-btn-sim::after {
  content: ""; position: absolute; top: 0; left: -120%;
  width: 60%; height: 100%;
  background: linear-gradient(105deg, transparent, rgba(255,255,255,0.25), transparent);
  animation: cc-sweep 4.2s ease-in-out infinite;
  pointer-events: none;
}
@keyframes cc-sweep { 0%, 70% { left: -120%; } 100% { left: 140%; } }

.cc-lock-meta { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--dm-text-dead); padding: 0 0.25rem; }

/* Proof bar */
.cc-proof {
  display: grid; grid-template-columns: auto 1fr auto auto; gap: 14px; align-items: center;
  padding: 0.7rem 1rem;
  border: 1px solid var(--dm-border);
  border-radius: 6px;
  background: rgba(15,23,42,0.55);
}
.cc-proof .tag { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dm-cyan); border: 1px solid rgba(34,211,238,0.35); padding: 4px 8px; border-radius: 999px; background: rgba(34,211,238,0.06); }
.cc-proof .copy { color: var(--dm-text-muted); font-size: 0.82rem; line-height: 1.4; }
.cc-proof .copy b { color: var(--dm-text-secondary); font-weight: 600; }
.cc-proof .wkbadge { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em; color: var(--dm-cyan-bright); text-transform: uppercase; }
.cc-proof .show { font-family: var(--font-display); font-size: 0.72rem; letter-spacing: 0.08em; color: var(--dm-cyan-bright); cursor: pointer; background: none; border: 0; padding: 4px 8px; border-radius: 3px; }
.cc-proof .show:hover { color: #fff; background: rgba(34,211,238,0.08); }

/* Bye week hero variant */
.cc-hero.is-bye {
  grid-template-columns: 1fr;
  border-left-color: var(--dm-cyan);
  background:
    radial-gradient(ellipse 60% 80% at 0% 100%, rgba(34,211,238,0.08), transparent 60%),
    linear-gradient(180deg, rgba(15,23,42,0.92), rgba(2,6,23,0.96)),
    #0f172a;
}

/* Responsive */
@media (max-width: 1180px) {
  .cc-hero { grid-template-columns: 1fr; }
  .cc-hero-right { border-left: 0; border-top: 1px solid var(--dm-border); }
  .cc-body { grid-template-columns: 1fr 1fr; }
  .cc-body .cc-lock { grid-column: span 2; }
  .cc-id-strip { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 720px) {
  .cc-body { grid-template-columns: 1fr; }
  .cc-body .cc-lock { grid-column: span 1; }
  .cc-id-strip { grid-template-columns: 1fr 1fr; }
  .cc-hero-stats { grid-template-columns: 1fr 1fr; }
  .cc-policy { grid-template-columns: 1fr; }
  .cc-scout-grid { grid-template-columns: 1fr; }
  .cc-gates { grid-template-columns: repeat(3, minmax(0,1fr)); }
  .cc-proof { grid-template-columns: auto 1fr; }
  .cc-proof .wkbadge, .cc-proof .show { display: none; }
}


/* ============================================================
   ROSTER LAB
   ============================================================ */
.rl-shell { display: grid; gap: 1.1rem; width: 100%; max-width: 1440px; margin: 0 auto; }

/* Header */
.rl-head {
  display: flex; justify-content: space-between; align-items: flex-end; gap: 1.5rem; flex-wrap: wrap;
  padding: 1rem 0 0;
}
.rl-title { margin: 4px 0 0; font-family: var(--font-display); font-size: 1.5rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; }
.rl-sub { margin: 6px 0 0; color: var(--dm-text-muted); font-size: 0.85rem; max-width: 60ch; line-height: 1.5; }
.rl-head-actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

.rl-segment {
  display: inline-flex;
  border: 1px solid var(--dm-border-strong);
  border-radius: 4px;
  overflow: hidden;
  background: rgba(2,6,23,0.5);
}
.rl-seg-btn {
  border: 0; background: transparent;
  padding: 0.55rem 0.9rem;
  font-family: var(--font-display); font-size: 0.74rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
  color: var(--dm-text-muted);
  cursor: pointer;
  transition: all 140ms ease;
  border-right: 1px solid var(--dm-border);
}
.rl-seg-btn:last-child { border-right: 0; }
.rl-seg-btn:hover { color: #e2e8f0; }
.rl-seg-btn.is-active { background: rgba(34,211,238,0.10); color: var(--dm-cyan-bright); }

.rl-sort {
  border: 1px solid var(--dm-border-strong);
  border-radius: 4px;
  background: rgba(2,6,23,0.5);
  color: var(--dm-text-secondary);
  padding: 0.55rem 0.75rem;
  font-family: var(--font-display); font-size: 0.74rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
  cursor: pointer;
}

/* Glance row */
.rl-glance {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: rgba(15,23,42,0.7);
  overflow: hidden;
}
.rl-glance-cell {
  padding: 1rem 1.1rem;
  display: grid; gap: 8px; align-content: start;
  border-left: 1px solid var(--dm-border);
}
.rl-glance-cell:first-child { border-left: 0; }
.rl-glance-cell .lbl { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.22em; color: var(--dm-cyan); text-transform: uppercase; }

/* Lineup summary */
.rl-line-row { display: flex; gap: 6px; flex-wrap: wrap; }
.rl-line-pill {
  display: inline-flex; gap: 6px; align-items: baseline;
  padding: 4px 9px; border-radius: 3px;
  font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; letter-spacing: 0.02em;
  border: 1px solid;
}
.rl-line-pill span { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.14em; font-weight: 700; }
.rl-line-pill.starter  { border-color: rgba(34,211,238,0.45); background: rgba(34,211,238,0.10); color: var(--dm-cyan-bright); }
.rl-line-pill.rotation { border-color: rgba(167,139,250,0.45); background: rgba(167,139,250,0.10); color: #c4b5fd; }
.rl-line-pill.bench    { border-color: var(--dm-border-strong); background: rgba(2,6,23,0.5); color: var(--dm-text-muted); }
.rl-line-helper { margin: 0; font-size: 0.78rem; color: var(--dm-text-muted); line-height: 1.45; }

/* Archetype mix */
.rl-mix-bar {
  display: flex; height: 14px; border-radius: 2px; overflow: hidden;
  background: var(--dm-surface-elevated);
  border: 1px solid var(--dm-border);
}
.rl-mix-bar .seg { height: 100%; min-width: 4px; }
.rl-mix-legend { list-style: none; padding: 0; margin: 0; display: flex; gap: 12px; flex-wrap: wrap; font-family: var(--font-mono); font-size: 0.72rem; color: var(--dm-text-muted); letter-spacing: 0.04em; }
.rl-mix-legend li { display: inline-flex; gap: 6px; align-items: center; }
.rl-mix-legend .dot { width: 8px; height: 8px; border-radius: 2px; }
.rl-mix-legend .k { text-transform: uppercase; letter-spacing: 0.1em; }
.rl-mix-legend .v { color: #f1f5f9; font-weight: 800; }

/* Potential pyramid */
.rl-pot-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
.rl-pot-pip {
  display: grid; justify-items: center; gap: 2px;
  padding: 8px 6px;
  border: 1px solid var(--dm-border-strong);
  background: rgba(2,6,23,0.5);
  border-radius: 3px;
}
.rl-pot-pip .glyph { font-family: var(--font-display); font-size: 1rem; font-weight: 800; line-height: 1; }
.rl-pot-pip .num { font-family: var(--font-mono); font-size: 1.05rem; font-weight: 900; color: #fff; line-height: 1; font-variant-numeric: tabular-nums; }
.rl-pot-pip .name { font-family: var(--font-mono); font-size: 0.55rem; letter-spacing: 0.14em; color: var(--dm-text-muted); text-transform: uppercase; }
.rl-pot-pip.tier-elite   { border-color: rgba(250,204,21,0.55); background: rgba(250,204,21,0.08); }
.rl-pot-pip.tier-elite .glyph { color: #facc15; }
.rl-pot-pip.tier-high    { border-color: rgba(34,211,238,0.45); background: rgba(34,211,238,0.06); }
.rl-pot-pip.tier-high .glyph { color: var(--dm-cyan); }
.rl-pot-pip.tier-solid   { border-color: rgba(132,204,22,0.45); background: rgba(132,204,22,0.06); }
.rl-pot-pip.tier-solid .glyph { color: #84cc16; }
.rl-pot-pip.tier-limited { border-color: rgba(148,163,184,0.3); background: rgba(2,6,23,0.5); }
.rl-pot-pip.tier-limited .glyph { color: #94a3b8; }

/* Age curve */
.rl-age-row { display: grid; grid-template-columns: auto 1fr; gap: 12px; align-items: end; min-height: 70px; }
.rl-age-stat { display: grid; gap: 2px; }
.rl-age-stat .big { font-family: var(--font-mono); font-size: 1.8rem; font-weight: 900; color: #f1f5f9; line-height: 1; font-variant-numeric: tabular-nums; }
.rl-age-stat .dim { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.14em; color: var(--dm-text-muted); text-transform: uppercase; }
.rl-age-bars { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; align-items: end; height: 60px; }
.rl-age-col { display: grid; align-items: end; justify-items: center; gap: 2px; height: 100%; grid-template-rows: 1fr auto auto; }
.rl-age-col .bar { width: 100%; max-width: 24px; background: var(--dm-cyan); min-height: 2px; border-radius: 2px 2px 0 0; align-self: end; }
.rl-age-col .lbl-mini { font-family: var(--font-mono); font-size: 0.55rem; letter-spacing: 0.1em; color: var(--dm-text-dead); text-transform: uppercase; }
.rl-age-col .ct { font-family: var(--font-mono); font-size: 0.68rem; font-weight: 800; color: #f1f5f9; }

/* Table */
.rl-table-card {
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: var(--dm-surface-translucent);
  overflow: hidden;
}
.rl-table-scroll { overflow-x: auto; }
.rl-table { width: 100%; border-collapse: collapse; }
.rl-table thead th {
  padding: 0.65rem 1rem; text-align: left;
  font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.18em; font-weight: 700; text-transform: uppercase; color: var(--dm-text-dead);
  background: rgba(2,6,23,0.55); border-bottom: 1px solid var(--dm-border);
}
.rl-table thead th.num { text-align: center; }
.rl-table tbody tr { border-bottom: 1px solid rgba(30,41,59,0.55); transition: background 140ms ease; }
.rl-table tbody tr:hover { background: rgba(30,41,59,0.4); }
.rl-table tbody tr.rl-row-starter { background: rgba(34,211,238,0.025); }
.rl-table tbody tr.rl-row-elite { box-shadow: inset 2px 0 0 rgba(250,204,21,0.6); }
.rl-table td { padding: 0.7rem 1rem; vertical-align: middle; }
.rl-table td.num { text-align: center; }

.rl-rank { font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700; color: var(--dm-text-dead); letter-spacing: 0.05em; }

.rl-player { display: grid; gap: 3px; min-width: 0; }
.rl-player-name { font-family: var(--font-display); font-size: 1rem; font-weight: 800; letter-spacing: 0.03em; text-transform: uppercase; color: #fff; }
.rl-player-meta { display: flex; gap: 6px; align-items: center; font-family: var(--font-mono); font-size: 0.72rem; color: var(--dm-text-muted); letter-spacing: 0.04em; flex-wrap: wrap; }
.rl-player-meta .dot { color: var(--dm-border-strong); }
.rl-pin { color: var(--dm-cyan-bright); font-size: 0.55rem; margin-left: 4px; }

.rl-ratings { display: grid; grid-template-columns: repeat(3, minmax(80px, 1fr)); gap: 4px 10px; min-width: 280px; }
.rl-rmini { display: grid; grid-template-columns: 28px 22px 1fr; gap: 6px; align-items: center; font-family: var(--font-mono); font-size: 0.7rem; }
.rl-rmini-lbl { color: var(--dm-text-muted); letter-spacing: 0.08em; font-size: 0.6rem; text-transform: uppercase; }
.rl-rmini-val { text-align: right; font-weight: 700; font-variant-numeric: tabular-nums; }
.rl-rmini.tier-elite .rl-rmini-val { color: var(--dm-cyan-bright); }
.rl-rmini.tier-good  .rl-rmini-val { color: var(--dm-emerald-bright); }
.rl-rmini.tier-avg   .rl-rmini-val { color: var(--dm-amber-bright); }
.rl-rmini.tier-poor  .rl-rmini-val { color: var(--dm-rose); }
.rl-rmini-bar { display: block; height: 4px; border-radius: 2px; background: var(--dm-surface-elevated); overflow: hidden; }
.rl-rmini-bar .fill { display: block; height: 100%; border-radius: 2px; }
.rl-rmini.tier-elite .fill { background: var(--dm-cyan-bright); }
.rl-rmini.tier-good  .fill { background: var(--dm-emerald-bright); }
.rl-rmini.tier-avg   .fill { background: var(--dm-amber-bright); }
.rl-rmini.tier-poor  .fill { background: var(--dm-rose); }

.rl-num { font-family: var(--font-mono); font-size: 0.85rem; font-weight: 700; font-variant-numeric: tabular-nums; }
.rl-num.tier-elite { color: var(--dm-cyan-bright); }
.rl-num.tier-good  { color: var(--dm-emerald-bright); }
.rl-num.tier-avg   { color: var(--dm-amber-bright); }
.rl-num.tier-poor  { color: var(--dm-rose); }

.rl-potential { display: flex; gap: 10px; align-items: center; }
.rl-gem {
  display: inline-grid; place-items: center;
  width: 28px; height: 28px; border-radius: 999px;
  border: 1px solid;
  font-family: var(--font-display); font-size: 0.82rem; font-weight: 800; line-height: 1;
}
.rl-gem.tier-elite   { color: #facc15; background: rgba(250,204,21,0.10); border-color: rgba(250,204,21,0.55); box-shadow: 0 0 14px rgba(250,204,21,0.3); }
.rl-gem.tier-high    { color: var(--dm-cyan); background: rgba(34,211,238,0.10); border-color: rgba(34,211,238,0.45); }
.rl-gem.tier-solid   { color: #84cc16; background: rgba(132,204,22,0.10); border-color: rgba(132,204,22,0.45); }
.rl-gem.tier-limited { color: #94a3b8; background: rgba(148,163,184,0.06); border-color: rgba(148,163,184,0.3); }
.rl-pot-info { display: grid; gap: 2px; }
.rl-pot-tier { font-family: var(--font-display); font-size: 0.82rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; line-height: 1; }
.rl-pot-conf { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.06em; color: var(--dm-text-muted); }

.rl-ovr { display: inline-grid; gap: 4px; justify-items: end; min-width: 70px; }
.rl-ovr-val { font-family: var(--font-mono); font-size: 1.45rem; font-weight: 900; line-height: 1; color: var(--dm-cyan-bright); font-variant-numeric: tabular-nums; }
.rl-ovr-spark { display: block; width: 60px; height: 3px; border-radius: 999px; background: var(--dm-surface-elevated); overflow: hidden; }
.rl-ovr-fill { display: block; height: 100%; background: var(--dm-cyan); border-radius: 999px; }

.rl-table-foot {
  display: flex; gap: 14px; align-items: center; flex-wrap: wrap;
  padding: 0.7rem 1rem;
  border-top: 1px solid var(--dm-border);
  background: rgba(2,6,23,0.4);
}
.rl-foot-item { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-display); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--dm-text-muted); }
.rl-foot-item .rl-gem { width: 18px; height: 18px; font-size: 0.62rem; }
.rl-foot-sep { color: var(--dm-border-strong); }
.rl-foot-note { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.1em; color: var(--dm-text-dead); text-transform: uppercase; }

@media (max-width: 1180px) {
  .rl-glance { grid-template-columns: repeat(2, 1fr); }
  .rl-glance-cell:nth-child(3), .rl-glance-cell:nth-child(4) { border-top: 1px solid var(--dm-border); }
  .rl-glance-cell:nth-child(3) { border-left: 0; }
}
@media (max-width: 720px) {
  .rl-glance { grid-template-columns: 1fr; }
  .rl-glance-cell { border-left: 0; border-top: 1px solid var(--dm-border); }
  .rl-glance-cell:first-child { border-top: 0; }
}

/* ============================================================
   DYNASTY OFFICE — Front Office
   ============================================================ */
.do-shell { display: grid; gap: 1.1rem; width: 100%; max-width: 1440px; margin: 0 auto; }
.do-tab-content { display: grid; gap: 1rem; }

/* Tabs */
.do-tabs {
  display: flex; align-items: stretch; gap: 0;
  border-bottom: 1px solid var(--dm-border);
  padding: 0 4px;
}
.do-tab {
  display: inline-flex; align-items: center; gap: 8px;
  border: 0; background: transparent;
  padding: 0.85rem 1.1rem 0.75rem;
  font-family: var(--font-display); font-size: 0.85rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
  color: var(--dm-text-muted);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: color 140ms ease, border-color 140ms ease;
}
.do-tab:hover { color: #e2e8f0; }
.do-tab.is-active { color: var(--dm-cyan-bright); border-bottom-color: var(--dm-cyan); }
.do-tab-count {
  font-family: var(--font-mono); font-size: 0.6rem; font-weight: 800; letter-spacing: 0.08em;
  padding: 1px 6px; border-radius: 3px;
  border: 1px solid var(--dm-border-strong); background: rgba(15,23,42,0.6); color: var(--dm-text-dead);
}
.do-tab.is-active .do-tab-count { border-color: rgba(34,211,238,0.45); color: var(--dm-cyan-bright); background: rgba(34,211,238,0.10); }
.do-tabs-spacer { flex: 1; }
.do-tabs-note { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em; color: var(--dm-text-dead); text-transform: uppercase; align-self: center; padding: 0 8px; }

/* Credibility hero */
.do-cred {
  display: grid; grid-template-columns: auto minmax(0, 1.6fr) minmax(220px, 1fr);
  gap: 1.4rem;
  padding: 1.5rem 1.6rem;
  border: 1px solid var(--dm-border);
  border-left: 2px solid var(--dm-amber);
  border-radius: var(--radius-md);
  background:
    radial-gradient(ellipse 50% 100% at 0% 50%, rgba(245,158,11,0.10), transparent 60%),
    var(--dm-surface-translucent);
  box-shadow: 0 20px 50px rgba(0,0,0,0.4);
}
.do-cred-letter { position: relative; display: grid; place-items: center; width: 120px; height: 120px; flex-shrink: 0; }
.do-cred-letter .tier {
  font-family: var(--font-display); font-size: 6rem; font-weight: 900; line-height: 0.85;
  color: var(--dm-amber-bright);
  text-shadow: 0 0 60px rgba(245,158,11,0.45);
  letter-spacing: -0.02em;
  position: relative; z-index: 1;
}
.do-cred-letter .halo {
  position: absolute; inset: 0;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(245,158,11,0.22), transparent 65%);
  pointer-events: none;
}

.do-cred-main { display: grid; gap: 0.7rem; align-content: start; min-width: 0; }
.do-cred-title { margin: 4px 0 0; font-family: var(--font-display); font-size: 2rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; line-height: 1; }
.do-cred-blurb { margin: 0; color: var(--dm-text-secondary); font-size: 0.92rem; line-height: 1.5; max-width: 56ch; }

.do-cred-progress { display: grid; gap: 6px; padding-top: 4px; }
.do-cred-progress-head { display: flex; justify-content: space-between; align-items: baseline; }
.do-cred-progress-head .lbl { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.2em; color: var(--dm-cyan); text-transform: uppercase; }
.do-cred-progress-head .val { font-family: var(--font-mono); font-size: 0.85rem; }
.do-cred-progress-head .val b { font-size: 1.1rem; font-weight: 800; color: var(--dm-amber-bright); }
.do-cred-progress-head .val .dim { color: var(--dm-text-dead); }

.do-cred-track {
  position: relative; height: 32px;
  background: rgba(2,6,23,0.6);
  border: 1px solid var(--dm-border);
  border-radius: 4px;
  padding: 8px 0;
}
.do-cred-fill {
  position: relative; height: 16px;
  background: linear-gradient(90deg, rgba(245,158,11,0.25), var(--dm-amber-bright));
  border-radius: 0 4px 4px 0;
  margin-left: 0;
}
.do-cred-marker {
  position: absolute; right: 0; top: -4px; bottom: -4px;
  width: 3px;
  background: #fff;
  box-shadow: 0 0 12px rgba(255,255,255,0.6);
}
.do-cred-tick {
  position: absolute; top: 0; bottom: 0;
  width: 1px; background: transparent;
  display: grid; place-items: end center;
}
.do-cred-tick::before { content: ''; position: absolute; top: 0; left: 0; width: 1px; height: 100%; background: var(--dm-border-strong); }
.do-cred-tick .lbl { position: absolute; top: -22px; transform: translateX(-50%); font-family: var(--font-mono); font-size: 0.62rem; font-weight: 800; color: var(--dm-text-dead); letter-spacing: 0.04em; }

.do-cred-evidence { list-style: none; padding: 0; margin: 0.4rem 0 0; display: grid; gap: 0.4rem; }
.do-cred-evidence li { display: grid; grid-template-columns: 28px 1fr; gap: 8px; align-items: baseline; }
.do-cred-evidence .ix { font-family: var(--font-mono); font-size: 0.72rem; font-weight: 800; color: var(--dm-amber-bright); letter-spacing: 0.04em; }
.do-cred-evidence .copy { color: var(--dm-text-secondary); font-size: 0.85rem; line-height: 1.5; }

.do-cred-side { display: grid; gap: 0.6rem; align-content: start; }
.do-cred-rank {
  padding: 0.7rem 0.85rem;
  border: 1px solid var(--dm-border);
  border-left: 2px solid var(--dm-border-strong);
  border-radius: 4px;
  background: rgba(2,6,23,0.5);
  display: grid; gap: 4px;
}
.do-cred-rank.danger { border-left-color: var(--dm-amber); }
.do-cred-rank .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; color: var(--dm-text-dead); text-transform: uppercase; }
.do-cred-rank .val { display: flex; align-items: baseline; gap: 8px; }
.do-cred-rank .val b { font-family: var(--font-mono); font-size: 1.6rem; font-weight: 900; color: #fff; line-height: 1; font-variant-numeric: tabular-nums; }
.do-cred-rank .val span { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.18em; color: var(--dm-text-muted); text-transform: uppercase; }
.do-cred-rank .trend { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.08em; color: var(--dm-emerald-bright); }
.do-cred-rank .trend.dim { color: var(--dm-text-muted); }
.do-cred-rank .trend.warn { color: var(--dm-amber-bright); }

/* Slot meter / staff brief row */
.do-grid-row { display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr); gap: 1.1rem; }

.do-slots, .do-staff {
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: var(--dm-surface-translucent);
  overflow: hidden;
}
.do-panel-head {
  display: grid; gap: 4px;
  padding: 1rem 1.2rem;
  border-bottom: 1px solid var(--dm-border);
  background: rgba(2,6,23,0.4);
}
.do-panel-head h3 { margin: 0; font-family: var(--font-display); font-size: 1.2rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; }

.do-slot-body { padding: 1rem 1.2rem; display: grid; gap: 1rem; }
.do-slot { display: grid; gap: 6px; }
.do-slot-head { display: flex; justify-content: space-between; align-items: baseline; }
.do-slot-lbl { font-family: var(--font-display); font-size: 0.85rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; color: #f1f5f9; }
.do-slot-count { font-family: var(--font-mono); font-size: 0.85rem; color: var(--dm-text-muted); }
.do-slot-count b { font-family: var(--font-mono); font-size: 1.1rem; font-weight: 800; color: #fff; margin-right: 4px; }
.do-slot-pips { display: flex; gap: 4px; }
.do-slot-pip {
  flex: 1; height: 12px; border-radius: 2px;
  border: 1px solid var(--dm-border-strong);
  background: rgba(2,6,23,0.6);
}
.do-slot.tone-cyan   .do-slot-pip.used { background: var(--dm-cyan); border-color: var(--dm-cyan); box-shadow: 0 0 8px rgba(34,211,238,0.5); }
.do-slot.tone-amber  .do-slot-pip.used { background: var(--dm-amber); border-color: var(--dm-amber); box-shadow: 0 0 8px rgba(245,158,11,0.45); }
.do-slot.tone-orange .do-slot-pip.used { background: var(--dm-orange); border-color: var(--dm-orange); box-shadow: 0 0 8px rgba(249,115,22,0.5); }
.do-slot-help { font-size: 0.78rem; color: var(--dm-text-muted); line-height: 1.4; }

.do-staff-list { padding: 0.5rem 0; }
.do-staff-row {
  display: grid; grid-template-columns: 1fr auto; gap: 1rem; align-items: center;
  padding: 0.7rem 1.2rem;
  border-top: 1px solid rgba(30,41,59,0.5);
}
.do-staff-row:first-child { border-top: 0; }
.do-staff-id { display: grid; gap: 2px; min-width: 0; }
.do-staff-id .dept { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.18em; color: var(--dm-cyan); text-transform: uppercase; }
.do-staff-id .name { font-family: var(--font-display); font-size: 1rem; font-weight: 800; letter-spacing: 0.03em; text-transform: uppercase; color: #fff; }
.do-staff-id .voice { font-size: 0.78rem; color: var(--dm-text-muted); font-style: italic; }
.do-staff-rating { display: grid; gap: 2px; justify-items: end; }
.do-staff-rating .num { font-family: var(--font-mono); font-size: 1.6rem; font-weight: 900; color: #f1f5f9; line-height: 1; font-variant-numeric: tabular-nums; }
.do-staff-rating .lbl { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.18em; color: var(--dm-text-dead); text-transform: uppercase; }

/* Recruit board */
.do-board {
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: var(--dm-surface-translucent);
  overflow: hidden;
}
.do-board-head {
  padding: 1rem 1.2rem;
  border-bottom: 1px solid var(--dm-border);
  display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem; flex-wrap: wrap;
  background: rgba(2,6,23,0.4);
}
.do-board-head h3 { margin: 4px 0 0; font-family: var(--font-display); font-size: 1.4rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; }
.do-board-filters { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
.do-board-filter {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 6px 10px;
  border: 1px solid var(--dm-border-strong);
  background: rgba(2,6,23,0.5);
  color: var(--dm-text-muted);
  border-radius: 3px;
  font-family: var(--font-display); font-size: 0.74rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
  cursor: pointer;
  transition: all 140ms ease;
}
.do-board-filter:hover { border-color: var(--dm-cyan); color: var(--dm-cyan-bright); }
.do-board-filter.is-active { border-color: var(--dm-cyan); background: rgba(34,211,238,0.10); color: var(--dm-cyan-bright); }
.do-board-filter .n { font-family: var(--font-mono); font-size: 0.66rem; color: var(--dm-text-dead); }
.do-board-filter.is-active .n { color: var(--dm-cyan-bright); }
.do-board-sep { width: 1px; height: 18px; background: var(--dm-border-strong); margin: 0 4px; }
.do-board-meta { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em; color: var(--dm-text-dead); text-transform: uppercase; }

.do-board-grid {
  padding: 1rem 1.2rem;
  display: grid; gap: 1rem;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
}

.do-recruit {
  display: grid; gap: 0.7rem;
  padding: 1rem;
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: rgba(2,6,23,0.5);
  transition: border-color 140ms ease, transform 140ms ease;
}
.do-recruit:hover { border-color: var(--dm-border-strong); transform: translateY(-1px); }
.do-recruit.fit-strong { border-left: 2px solid var(--dm-emerald); }
.do-recruit.fit-risk   { border-left: 2px solid var(--dm-amber); }
.do-recruit.fit-neutral { border-left: 2px solid var(--dm-border-strong); }

.do-recruit-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
.do-recruit-id { min-width: 0; display: grid; gap: 4px; }
.do-recruit-name { font-family: var(--font-display); font-size: 0.95rem; font-weight: 800; letter-spacing: 0.03em; text-transform: uppercase; color: #fff; line-height: 1.15; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.do-recruit-sub { display: flex; gap: 6px; align-items: center; font-size: 0.74rem; color: var(--dm-text-muted); flex-wrap: wrap; }
.do-recruit-sub .dot { color: var(--dm-border-strong); }
.do-recruit-fit {
  display: grid; gap: 0; justify-items: end;
  padding: 4px 8px;
  border-radius: 3px;
}
.do-recruit.fit-strong .do-recruit-fit  { background: rgba(16,185,129,0.10); border: 1px solid rgba(16,185,129,0.3); }
.do-recruit.fit-risk .do-recruit-fit    { background: rgba(245,158,11,0.10); border: 1px solid rgba(245,158,11,0.3); }
.do-recruit.fit-neutral .do-recruit-fit { background: rgba(148,163,184,0.06); border: 1px solid rgba(148,163,184,0.25); }
.do-recruit-fit .lbl { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.16em; color: var(--dm-text-dead); text-transform: uppercase; }
.do-recruit-fit .val { font-family: var(--font-mono); font-size: 1.3rem; font-weight: 900; line-height: 1; font-variant-numeric: tabular-nums; }
.do-recruit.fit-strong .do-recruit-fit .val  { color: var(--dm-emerald-bright); }
.do-recruit.fit-risk .do-recruit-fit .val    { color: var(--dm-amber-bright); }
.do-recruit.fit-neutral .do-recruit-fit .val { color: #f1f5f9; }

.do-recruit-meter { display: grid; gap: 4px; }
.do-recruit-meter-bg { height: 5px; border-radius: 999px; background: var(--dm-surface-elevated); overflow: hidden; }
.do-recruit-meter-fill { height: 100%; border-radius: 999px; }
.do-recruit.fit-strong .do-recruit-meter-fill  { background: var(--dm-emerald-bright); }
.do-recruit.fit-risk .do-recruit-meter-fill    { background: var(--dm-amber-bright); }
.do-recruit.fit-neutral .do-recruit-meter-fill { background: var(--dm-text-muted); }
.do-recruit-meter-labels { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase; }
.do-recruit-meter-labels > span:first-child { color: var(--dm-text-muted); }
.do-recruit-meter-labels .ovr { color: #cbd5e1; font-weight: 700; }

.do-recruit-evidence {
  display: grid; grid-template-columns: 2px 1fr; gap: 10px;
  padding: 0.6rem 0;
}
.do-recruit-evidence .bar { background: var(--dm-border-strong); }
.do-recruit.fit-strong .do-recruit-evidence .bar { background: rgba(16,185,129,0.5); }
.do-recruit.fit-risk .do-recruit-evidence .bar   { background: rgba(245,158,11,0.5); }
.do-recruit-evidence .copy { color: var(--dm-text-secondary); font-size: 0.82rem; line-height: 1.5; font-style: italic; }

.do-recruit-actions { display: flex; gap: 6px; }
.do-recruit-btn {
  flex: 1;
  padding: 0.45rem 0.7rem;
  border: 1px solid var(--dm-border-strong);
  background: transparent;
  color: var(--dm-text-secondary);
  font-family: var(--font-display); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
  border-radius: 3px;
  cursor: pointer;
  transition: all 140ms ease;
}
.do-recruit-btn:hover { border-color: var(--dm-cyan); color: var(--dm-cyan-bright); }
.do-recruit-btn.primary { border-color: var(--dm-orange); background: var(--dm-orange-soft); color: var(--dm-orange-hover); }
.do-recruit-btn.primary:hover { background: var(--dm-orange); color: #fff; border-color: var(--dm-orange); }

@media (max-width: 1180px) {
  .do-cred { grid-template-columns: auto 1fr; }
  .do-cred-side { grid-column: 1 / -1; grid-template-columns: repeat(3, 1fr); }
  .do-grid-row { grid-template-columns: 1fr; }
}
@media (max-width: 720px) {
  .do-cred { grid-template-columns: 1fr; justify-items: center; text-align: center; }
  .do-cred-side { grid-template-columns: 1fr; }
}

/* ============================================================
   STANDINGS — League Office
   ============================================================ */
.ls-shell {
  display: grid;
  gap: 1.1rem;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
}
.ls-side { display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr); gap: 1.1rem; align-content: start; }

/* --- Glance row --- */
.ls-glance {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: rgba(15,23,42,0.7);
  overflow: hidden;
}
.ls-glance-cell {
  padding: 1.1rem 1.2rem;
  display: grid; gap: 8px; align-content: start;
  border-left: 1px solid var(--dm-border);
}
.ls-glance-cell:first-child { border-left: 0; }
.ls-glance-cell .lbl { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.22em; color: var(--dm-cyan); text-transform: uppercase; }
.ls-glance-cell .lbl-mini { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.16em; color: var(--dm-text-dead); text-transform: uppercase; }

.ls-glance-rank .rank-row { display: flex; align-items: baseline; gap: 8px; }
.ls-glance-rank .num { font-family: var(--font-mono); font-size: 3rem; font-weight: 900; line-height: 0.85; color: #f8fafc; font-variant-numeric: tabular-nums; }
.ls-glance-rank .suffix { font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.14em; color: var(--dm-text-muted); text-transform: uppercase; }
.ls-glance-rank .trend { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; }
.ls-glance-rank .trend.up   { color: var(--dm-emerald-bright); }
.ls-glance-rank .trend.down { color: var(--dm-rose); }
.ls-glance-rank .arrow { font-size: 0.65rem; }

.ls-glance-record .record-row { display: flex; align-items: baseline; gap: 12px; }
.ls-glance-record .rec { font-family: var(--font-mono); font-size: 2.2rem; font-weight: 800; color: #f8fafc; line-height: 1; font-variant-numeric: tabular-nums; }
.ls-glance-record .diff { font-family: var(--font-mono); font-size: 1.1rem; font-weight: 700; color: var(--dm-emerald-bright); letter-spacing: 0.04em; }
.ls-form-with-label { display: inline-flex; align-items: center; gap: 8px; }

.ls-glance-race .race { display: flex; gap: 6px; align-items: center; padding: 4px 0; }
.race-pip {
  display: inline-grid; place-items: center;
  width: 32px; height: 32px;
  border-radius: 3px;
  font-family: var(--font-mono); font-weight: 800;
  border: 1px solid var(--dm-border-strong);
  background: rgba(15,23,42,0.6);
  color: var(--dm-text-muted);
  position: relative;
}
.race-pip.in  { border-color: rgba(16,185,129,0.5); background: rgba(16,185,129,0.10); color: var(--dm-emerald-bright); }
.race-pip.out { border-color: rgba(148,163,184,0.3); background: rgba(2,6,23,0.5); color: var(--dm-text-dead); }
.race-pip.us  { border-color: var(--dm-cyan); background: rgba(34,211,238,0.15); color: var(--dm-cyan-bright); box-shadow: 0 0 14px rgba(34,211,238,0.25); }
.race-pip.us .rk { font-weight: 900; }
.race-pip .rk { font-size: 0.85rem; }

.ls-glance-race .cushion { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; color: var(--dm-text-muted); display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
.ls-glance-race .cushion-pos  { color: var(--dm-emerald-bright); }
.ls-glance-race .cushion-back { color: var(--dm-amber-bright); }
.ls-glance-race .cushion-sep  { color: var(--dm-border-strong); }

.ls-glance-next .need-row { display: flex; align-items: center; gap: 8px; }
.ls-glance-next .need-action { font-family: var(--font-display); font-size: 1.05rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; color: var(--dm-orange-hover); padding: 4px 10px; border: 1px solid rgba(249,115,22,0.45); border-radius: 3px; background: rgba(249,115,22,0.08); }
.ls-glance-next .need-arrow { color: var(--dm-text-dead); font-family: var(--font-mono); }
.ls-glance-next .need-outcome { font-family: var(--font-display); font-size: 1.05rem; font-weight: 800; letter-spacing: 0.04em; color: var(--dm-emerald-bright); text-transform: uppercase; }
.ls-glance-next .need-helper { margin: 0; color: var(--dm-text-muted); font-size: 0.78rem; line-height: 1.45; }

/* --- Form pips --- */
.ls-form { display: inline-flex; gap: 3px; }
.ls-form-pip {
  display: inline-grid; place-items: center;
  width: 18px; height: 18px;
  border-radius: 2px;
  font-family: var(--font-mono); font-size: 0.62rem; font-weight: 800; letter-spacing: 0;
  border: 1px solid;
}
.ls-form-pip.pip-w { border-color: rgba(16,185,129,0.55); background: rgba(16,185,129,0.18); color: var(--dm-emerald-bright); }
.ls-form-pip.pip-l { border-color: rgba(244,63,94,0.55); background: rgba(244,63,94,0.15); color: #fb7185; }
.ls-form-pip.pip-d { border-color: rgba(148,163,184,0.45); background: rgba(148,163,184,0.10); color: var(--dm-text-muted); }

/* --- Table --- */
.ls-table-card {
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: var(--dm-surface-translucent);
  overflow: hidden;
}
.ls-table-head {
  display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--dm-border);
}
.ls-table-title { margin: 4px 0 0; font-family: var(--font-display); font-size: 1.4rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; white-space: nowrap; }
.ls-subtle { color: var(--dm-text-muted); font-weight: 500; font-size: 0.78rem; letter-spacing: 0.06em; margin-left: 8px; white-space: nowrap; }
.ls-table-meta { display: flex; gap: 6px; flex-wrap: wrap; flex-shrink: 0; }

.ls-table-scroll { overflow-x: auto; }
.ls-table { width: 100%; border-collapse: collapse; }
.ls-table thead th {
  padding: 0.65rem 1rem; text-align: left;
  font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dm-text-dead);
  background: rgba(2,6,23,0.55); border-bottom: 1px solid var(--dm-border);
  font-weight: 700;
}
.ls-table thead th.num { text-align: center; }
.ls-table tbody tr { border-bottom: 1px solid rgba(30,41,59,0.55); transition: background 140ms ease; }
.ls-table tbody tr:hover { background: rgba(30,41,59,0.35); }
.ls-table td { padding: 0.7rem 1rem; vertical-align: middle; }
.ls-table td.num { text-align: center; }

.ls-table tr.ls-user { background: rgba(34,211,238,0.06); border-left: 2px solid var(--dm-cyan); }
.ls-table tr.ls-user:hover { background: rgba(34,211,238,0.10); }
.ls-table tr.ls-user .club-name { color: var(--dm-cyan-bright); font-weight: 800; }

.ls-rank { font-family: var(--font-mono); font-size: 0.9rem; font-weight: 800; display: inline-grid; place-items: center; min-width: 22px; }
.ls-rank.in  { color: var(--dm-emerald-bright); }
.ls-rank.out { color: var(--dm-text-dead); }
.ls-club .club-name { font-family: var(--font-display); font-size: 0.92rem; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; color: #f1f5f9; }
.ls-cell-num { font-family: var(--font-mono); font-size: 0.85rem; font-variant-numeric: tabular-nums; color: #cbd5e1; }
.ls-cell-num.muted { color: var(--dm-text-muted); }
.ls-cell-num.pts   { color: #fff; font-weight: 800; font-size: 0.95rem; }

/* playoff cut line */
.ls-playoff-line td { padding: 0; border-bottom: 0; background: linear-gradient(180deg, rgba(249,115,22,0.06), transparent); }
.ls-playoff-line .cut-row { display: flex; align-items: center; gap: 10px; padding: 0.4rem 1rem; }
.ls-playoff-line .line-bar { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, var(--dm-orange) 50%, transparent); }
.ls-playoff-line .line-label { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.28em; color: var(--dm-orange-hover); text-transform: uppercase; padding: 2px 8px; border: 1px solid rgba(249,115,22,0.45); border-radius: 999px; background: rgba(249,115,22,0.10); white-space: nowrap; }

/* Diff bar */
.ls-diff-cell { display: inline-flex; align-items: center; gap: 10px; }
.ls-diff-bar { position: relative; width: 110px; height: 16px; flex-shrink: 0; }
.ls-diff-bar .axis { position: absolute; left: 50%; top: 0; bottom: 0; width: 1px; background: var(--dm-border-strong); }
.ls-diff-bar .fill { position: absolute; top: 4px; bottom: 4px; border-radius: 1px; }
.ls-diff-bar .fill.pos { background: var(--dm-emerald-bright); }
.ls-diff-bar .fill.neg { background: var(--dm-rose); }
.ls-diff-val { font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700; font-variant-numeric: tabular-nums; min-width: 34px; }
.ls-diff-val.pos { color: var(--dm-emerald-bright); }
.ls-diff-val.neg { color: var(--dm-rose); }

.ls-table-foot {
  padding: 0.7rem 1.25rem;
  display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
  border-top: 1px solid var(--dm-border);
  background: rgba(2,6,23,0.4);
}
.ls-legend-item { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em; color: var(--dm-text-muted); text-transform: uppercase; }
.ls-legend-sep { color: var(--dm-border-strong); }
.ls-legend-note { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.12em; color: var(--dm-text-dead); text-transform: uppercase; }

/* --- Side panels --- */
.ls-panel {
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: var(--dm-surface-translucent);
  overflow: hidden;
}
.ls-panel-head { padding: 0.95rem 1.1rem; border-bottom: 1px solid var(--dm-border); display: grid; gap: 4px; }
.ls-panel-head h3 { margin: 0; font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; }

.ls-wire-list { list-style: none; padding: 0; margin: 0; }
.ls-wire-row {
  display: grid; grid-template-columns: 36px 1fr auto; gap: 10px;
  padding: 0.7rem 1.1rem;
  border-top: 1px solid rgba(30,41,59,0.5);
  align-items: center;
}
.ls-wire-row:first-child { border-top: 0; }
.ls-wire-row.is-us { background: rgba(34,211,238,0.05); }
.ls-wire-week { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.18em; color: var(--dm-cyan); text-transform: uppercase; }
.ls-wire-fixture { display: grid; grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr); gap: 10px; align-items: center; }
.ls-wire-team { font-family: var(--font-display); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: #cbd5e1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ls-wire-team.home { text-align: right; }
.ls-wire-team.away { text-align: left; }
.ls-wire-score { display: inline-flex; align-items: baseline; gap: 4px; font-family: var(--font-mono); font-size: 0.95rem; font-variant-numeric: tabular-nums; color: var(--dm-text-muted); }
.ls-wire-score b { color: #fff; font-weight: 800; font-size: 1.05rem; }
.ls-wire-tag {
  font-family: var(--font-mono); font-size: 0.58rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase;
  padding: 2px 6px; border-radius: 2px; border: 1px solid;
}
.ls-wire-tag.tag-win  { color: var(--dm-emerald-bright); border-color: rgba(16,185,129,0.45); background: rgba(16,185,129,0.10); }
.ls-wire-tag.tag-draw { color: var(--dm-text-muted); border-color: rgba(148,163,184,0.45); background: rgba(148,163,184,0.08); }

/* Tiebreaker panel */
.ls-tb-list { display: grid; }
.ls-tb-row {
  display: grid; grid-template-columns: 36px 1fr auto;
  gap: 10px; align-items: center;
  padding: 0.7rem 1.1rem;
  border-top: 1px solid rgba(30,41,59,0.5);
}
.ls-tb-row:first-child { border-top: 0; }
.ls-tb-from { font-family: var(--font-mono); font-size: 0.85rem; font-weight: 800; color: #f8fafc; }
.ls-tb-body { display: grid; gap: 2px; min-width: 0; }
.ls-tb-who { font-family: var(--font-display); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; color: #f1f5f9; }
.ls-tb-note { font-family: var(--font-mono); font-size: 0.66rem; color: var(--dm-text-muted); letter-spacing: 0.04em; }
.ls-tb-risk {
  font-family: var(--font-mono); font-size: 0.58rem; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase;
  padding: 3px 7px; border-radius: 2px; border: 1px solid;
}
.ls-tb-risk.risk-high { color: var(--dm-amber-bright); border-color: rgba(245,158,11,0.5); background: rgba(245,158,11,0.10); }
.ls-tb-risk.risk-low  { color: var(--dm-emerald-bright); border-color: rgba(16,185,129,0.45); background: rgba(16,185,129,0.08); }

@media (max-width: 1180px) {
  .ls-shell {
    grid-template-columns: 1fr;
    grid-template-areas: "glance" "table" "side";
  }
  .ls-glance { grid-template-columns: repeat(2, 1fr); }
  .ls-glance-cell:nth-child(3) { border-left: 0; border-top: 1px solid var(--dm-border); }
  .ls-glance-cell:nth-child(4) { border-top: 1px solid var(--dm-border); }
}
@media (max-width: 720px) {
  .ls-glance { grid-template-columns: 1fr; }
  .ls-glance-cell { border-left: 0; border-top: 1px solid var(--dm-border); }
  .ls-glance-cell:first-child { border-top: 0; }
}

/* ============================================================
   MATCH REPLAY — broadcast scoreboard + dark court + log
   ============================================================ */
.max-content.mr-shell { display: grid; grid-template-columns: minmax(0, 1.55fr) minmax(320px, 1fr); gap: 1.1rem; align-items: start; }
.max-content.mr-shell > .mr-scoreboard,
.max-content.mr-shell > .mr-turning { grid-column: 1 / -1; }

/* --- Scoreboard --- */
.mr-scoreboard {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: stretch;
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  background:
    radial-gradient(ellipse 50% 90% at 0% 50%, rgba(244,63,94,0.10), transparent 60%),
    radial-gradient(ellipse 50% 90% at 100% 50%, rgba(59,130,246,0.10), transparent 60%),
    linear-gradient(180deg, rgba(15,23,42,0.94), rgba(2,6,23,0.96));
  box-shadow: 0 22px 60px rgba(0,0,0,0.4);
}
.mr-team { padding: 1.1rem 1.4rem; display: grid; gap: 6px; align-content: center; min-width: 0; }
.mr-team.away { text-align: right; justify-items: end; }
.mr-team .mr-team-rec { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--dm-text-dead); }
.mr-team .mr-team-name { font-family: var(--font-display); font-size: clamp(1.4rem, 2.4vw, 2rem); font-weight: 800; line-height: 1; letter-spacing: 0.02em; text-transform: uppercase; color: #f8fafc; }
.mr-team .mr-team-tag { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dm-text-muted); }
.mr-team.home { border-left: 2px solid var(--dm-rose); }
.mr-team.away { border-right: 2px solid var(--dm-blue); }
.mr-team.home .mr-team-tag { color: #fb7185; }
.mr-team.away .mr-team-tag { color: #60a5fa; }

.mr-score {
  display: grid; grid-template-columns: auto auto auto; align-items: center; gap: 1rem;
  padding: 0.6rem 1.6rem;
  background: rgba(2,6,23,0.5);
  border-left: 1px solid var(--dm-border);
  border-right: 1px solid var(--dm-border);
}
.mr-score-num { font-family: var(--font-mono); font-size: clamp(3rem, 6vw, 5rem); font-weight: 900; line-height: 0.85; font-variant-numeric: tabular-nums; }
.mr-score-num.home { color: #fb7185; text-shadow: 0 0 28px rgba(244,63,94,0.4); }
.mr-score-num.away { color: #94a3b8; }
.mr-score-divider { display: grid; justify-items: center; gap: 6px; padding: 0 8px; }
.mr-final-tag { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.24em; color: var(--dm-orange-hover); text-transform: uppercase; border: 1px solid rgba(249,115,22,0.4); padding: 3px 8px; border-radius: 3px; background: rgba(249,115,22,0.08); }
.mr-score-divider .mr-vs { font-family: var(--font-display); font-size: 1.3rem; color: var(--dm-border-strong); font-weight: 800; letter-spacing: 0.18em; }
.mr-score-divider .mr-margin { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.18em; color: var(--dm-emerald-bright); text-transform: uppercase; }

/* --- Turning point --- */
.mr-turning {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 1rem; align-items: center;
  padding: 0.85rem 1.1rem;
  border: 1px solid rgba(34,211,238,0.28);
  border-left: 2px solid var(--dm-cyan);
  border-radius: var(--radius-md);
  background:
    linear-gradient(90deg, rgba(34,211,238,0.08), rgba(34,211,238,0.0) 70%),
    rgba(15,23,42,0.6);
}
.mr-turning-kicker { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.24em; color: var(--dm-cyan-bright); text-transform: uppercase; display: block; }
.mr-turning-text { margin: 4px 0 0; color: #f1f5f9; font-size: 0.92rem; line-height: 1.5; font-weight: 500; }
.mr-turning-jump {
  display: inline-flex; align-items: center; gap: 8px;
  border: 1px solid rgba(34,211,238,0.45);
  background: rgba(34,211,238,0.08);
  color: var(--dm-cyan-bright);
  font-family: var(--font-display); font-size: 0.78rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 0.55rem 0.9rem; border-radius: 4px; cursor: pointer;
  transition: background 140ms ease, color 140ms ease;
}
.mr-turning-jump:hover { background: var(--dm-cyan); color: #020617; }
.mr-turning-jump .arrow { font-family: var(--font-mono); font-weight: 800; }

/* --- Stage (court + possession + transport) --- */
.mr-stage {
  display: grid; gap: 0;
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: rgba(15,23,42,0.7);
}
.mr-court-wrap {
  position: relative;
  padding: 14px;
  background:
    radial-gradient(ellipse 60% 80% at 50% 50%, rgba(34,211,238,0.05), transparent 60%),
    #020617;
}
.mr-court-svg { display: block; width: 100%; max-width: 760px; margin: 0 auto; height: auto; }
.mr-active-readout {
  display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  padding: 0.55rem 0.9rem;
  border-bottom: 1px solid var(--dm-border);
  background: rgba(2,6,23,0.55);
}
.mr-active-readout .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.22em; color: var(--dm-cyan-bright); text-transform: uppercase; }
.mr-active-readout .sep { width: 1px; height: 14px; background: var(--dm-border-strong); }
.mr-active-readout .val { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em; color: var(--dm-text-muted); text-transform: uppercase; }
.mr-active-readout .title { font-family: var(--font-display); font-size: 0.85rem; font-weight: 700; color: #fff; text-transform: uppercase; letter-spacing: 0.03em; flex: 1; min-width: 0; }

/* possession ribbon */
.mr-possession {
  padding: 0.9rem 1rem;
  background: rgba(2,6,23,0.5);
  border-top: 1px solid var(--dm-border);
  display: grid; gap: 0.55rem;
}
.mr-possession-head { display: flex; justify-content: space-between; align-items: baseline; }
.mr-possession-kicker { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.22em; color: var(--dm-cyan); text-transform: uppercase; }
.mr-possession-tally { display: inline-flex; gap: 8px; align-items: baseline; font-family: var(--font-mono); font-size: 0.7rem; }
.mr-possession-tally b { font-family: var(--font-display); font-size: 0.95rem; font-weight: 800; letter-spacing: 0.03em; }
.mr-possession-tally b.home { color: #fb7185; }
.mr-possession-tally b.away { color: #60a5fa; }
.mr-possession-tally .dim { color: var(--dm-text-muted); letter-spacing: 0.16em; text-transform: uppercase; font-size: 0.6rem; }
.mr-possession-tally .sep { color: var(--dm-border-strong); }

.mr-possession-strip { display: grid; grid-template-columns: repeat(7, minmax(0,1fr)); gap: 4px; }
.mr-poss-cell {
  position: relative;
  display: grid; justify-items: center; gap: 4px;
  padding: 0.55rem 0.4rem;
  border: 1px solid var(--dm-border);
  background: rgba(15,23,42,0.6);
  cursor: pointer;
  border-radius: 3px;
  transition: border-color 140ms ease, background 140ms ease, transform 140ms ease;
}
.mr-poss-cell .num { font-family: var(--font-mono); font-size: 0.68rem; font-weight: 800; letter-spacing: 0.08em; color: #f1f5f9; }
.mr-poss-cell .ph { font-family: var(--font-mono); font-size: 0.55rem; letter-spacing: 0.16em; color: var(--dm-text-muted); text-transform: uppercase; }
.mr-poss-cell.owner-home { border-bottom: 2px solid rgba(244,63,94,0.6); }
.mr-poss-cell.owner-away { border-bottom: 2px solid rgba(59,130,246,0.6); }
.mr-poss-cell.owner-swing { border-bottom: 2px solid var(--dm-cyan); background: rgba(34,211,238,0.08); }
.mr-poss-cell.owner-swing .num { color: var(--dm-cyan-bright); }
.mr-poss-cell.is-active { background: rgba(34,211,238,0.10); border-color: rgba(34,211,238,0.5); transform: translateY(-1px); box-shadow: 0 6px 18px rgba(0,0,0,0.4); }
.mr-poss-cell:hover { border-color: var(--dm-border-strong); }
.mr-poss-cell .swing-pip { position: absolute; top: 4px; right: 4px; width: 6px; height: 6px; border-radius: 999px; background: var(--dm-orange); box-shadow: 0 0 6px rgba(249,115,22,0.7); }

/* transport */
.mr-transport {
  display: flex; align-items: center; gap: 8px;
  padding: 0.65rem 1rem;
  background: rgba(2,6,23,0.6);
  border-top: 1px solid var(--dm-border);
}
.mr-tbtn {
  display: inline-grid; place-items: center;
  width: 34px; height: 34px;
  border: 1px solid var(--dm-border-strong);
  background: rgba(15,23,42,0.7);
  color: var(--dm-text-secondary);
  border-radius: 3px;
  font-family: var(--font-mono); font-size: 0.85rem;
  cursor: pointer;
  transition: border-color 140ms ease, color 140ms ease, background 140ms ease;
}
.mr-tbtn:hover { border-color: var(--dm-cyan); color: var(--dm-cyan-bright); }
.mr-tbtn.mr-play {
  width: 48px; border-color: var(--dm-orange); background: var(--dm-orange); color: #fff;
  box-shadow: 0 0 14px rgba(249,115,22,0.45);
}
.mr-tbtn.mr-play:hover { background: var(--dm-orange-hover); border-color: var(--dm-orange-hover); }
.mr-tbtn.mr-play.is-playing { font-size: 0.7rem; letter-spacing: 1px; }
.mr-transport-pos { margin-left: auto; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.14em; color: var(--dm-text-muted); text-transform: uppercase; }
.mr-transport-pos b { color: #f1f5f9; font-weight: 700; }
.mr-transport-spd { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.18em; color: var(--dm-text-dead); text-transform: uppercase; }

/* --- Sidebar / event log --- */
.mr-sidebar-wrap {
  display: flex; flex-direction: column;
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: rgba(15,23,42,0.7);
  overflow: hidden;
  max-height: calc(100vh - 180px);
  min-height: 600px;
}
.mr-sidebar-head {
  padding: 1rem 1.1rem;
  border-bottom: 1px solid var(--dm-border);
  display: grid; gap: 8px;
  background: rgba(2,6,23,0.5);
}
.mr-sidebar-title { margin: 4px 0 0; font-family: var(--font-display); font-size: 1.2rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; }
.mr-sidebar-meta { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; color: var(--dm-text-muted); text-transform: uppercase; }
.mr-sidebar-meta b { color: #f1f5f9; font-weight: 700; }
.mr-sidebar-meta .dot { color: var(--dm-border-strong); }

.mr-log { overflow-y: auto; flex: 1; scrollbar-width: thin; scrollbar-color: var(--dm-border-strong) transparent; }
.mr-log::-webkit-scrollbar { width: 6px; }
.mr-log::-webkit-scrollbar-thumb { background: var(--dm-border-strong); border-radius: 999px; }

.mr-log-group { display: flex; align-items: center; gap: 8px; padding: 0.55rem 1.1rem 0.35rem; }
.mr-log-group .bar { flex: 1; height: 1px; background: var(--dm-border); }
.mr-log-group .label { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.22em; color: var(--dm-text-dead); text-transform: uppercase; }

.mr-log-event {
  display: grid; grid-template-columns: 48px 1fr; gap: 12px;
  width: 100%; text-align: left;
  padding: 0.7rem 1.1rem;
  border: 0; border-top: 1px solid rgba(30,41,59,0.45);
  background: transparent; color: inherit; cursor: pointer;
  transition: background 140ms ease;
}
.mr-log-event:first-child { border-top: 0; }
.mr-log-event:hover { background: rgba(34,211,238,0.04); }
.mr-log-event.is-active { background: rgba(34,211,238,0.08); box-shadow: inset 2px 0 0 var(--dm-cyan); }
.mr-log-rail { display: grid; gap: 4px; text-align: center; }
.mr-log-tick { font-family: var(--font-mono); font-size: 0.74rem; font-weight: 800; color: var(--dm-text-muted); letter-spacing: 0.04em; }
.mr-log-event.is-active .mr-log-tick { color: var(--dm-cyan-bright); }
.mr-log-time { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.1em; color: var(--dm-text-dead); }
.mr-log-body { min-width: 0; }
.mr-log-row { display: flex; gap: 8px; align-items: baseline; flex-wrap: wrap; }
.mr-log-chip {
  font-family: var(--font-mono); font-size: 0.58rem; font-weight: 800; letter-spacing: 0.14em;
  padding: 2px 6px; border-radius: 2px; text-transform: uppercase;
  border: 1px solid var(--dm-border-strong); background: rgba(15,23,42,0.6); color: var(--dm-text-muted);
  flex-shrink: 0;
}
.mr-log-chip.chip-throw { border-color: rgba(249,115,22,0.4); background: var(--dm-orange-soft); color: var(--dm-orange-hover); }
.mr-log-chip.chip-elim  { border-color: rgba(244,63,94,0.4); background: var(--dm-rose-soft); color: #fb7185; }
.mr-log-chip.chip-catch { border-color: rgba(34,211,238,0.45); background: var(--dm-cyan-soft); color: var(--dm-cyan-bright); }
.mr-log-chip.chip-final { border-color: rgba(16,185,129,0.45); background: var(--dm-emerald-soft); color: var(--dm-emerald-bright); }
.mr-log-title { font-family: var(--font-body); font-size: 0.85rem; color: #f1f5f9; line-height: 1.4; font-weight: 500; }
.mr-log-evidence { margin: 6px 0 0; padding: 0; list-style: none; display: grid; gap: 3px; }
.mr-log-evidence li { font-family: var(--font-mono); font-size: 0.66rem; color: var(--dm-text-muted); padding-left: 10px; border-left: 1px solid var(--dm-border); line-height: 1.45; }

/* ============================================================
   DYNASTY OFFICE — HISTORY TAB
   ============================================================ */
.do-hist-glance {
  display: grid; grid-template-columns: repeat(5, minmax(0, 1fr));
  border: 1px solid var(--dm-border); border-radius: var(--radius-md);
  background: rgba(15,23,42,0.7); overflow: hidden;
}
.do-hist-glance .cell { padding: 1rem 1.1rem; border-left: 1px solid var(--dm-border); display: grid; gap: 6px; align-content: start; }
.do-hist-glance .cell:first-child { border-left: 0; }
.do-hist-glance .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.22em; color: var(--dm-cyan); text-transform: uppercase; }
.do-hist-glance .val { font-family: var(--font-display); font-size: 1.8rem; font-weight: 900; color: #f8fafc; letter-spacing: 0.03em; line-height: 1; text-transform: uppercase; }
.do-hist-glance .val span { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.18em; color: var(--dm-text-muted); margin-left: 6px; }
.do-hist-glance .trend { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em; color: var(--dm-text-muted); }
.do-hist-glance .trend.ok { color: var(--dm-emerald-bright); }

.do-hist-filters {
  display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
  padding: 0.8rem 1.1rem;
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: rgba(15,23,42,0.55);
}
.do-hist-filters .filters { display: flex; gap: 6px; flex-wrap: wrap; }
.do-hist-filters .do-board-meta { margin-left: auto; }

.do-hist-timeline {
  position: relative;
  display: grid; gap: 0;
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: var(--dm-surface-translucent);
  padding: 1.1rem 1.2rem 1.1rem 0;
  overflow: hidden;
}
.do-hist-timeline .rail {
  position: absolute; top: 0; bottom: 0; left: 84px;
  width: 1px; background: linear-gradient(180deg, transparent 0, var(--dm-border-strong) 16px, var(--dm-border-strong) calc(100% - 16px), transparent 100%);
}
.do-hist-entry {
  display: grid; grid-template-columns: 84px 1fr;
  align-items: stretch;
  padding: 0.85rem 0;
  border-top: 1px solid rgba(30,41,59,0.4);
}
.do-hist-entry:first-of-type { border-top: 0; }
.do-hist-wk {
  display: grid; justify-items: center; align-content: start;
  padding-top: 4px;
  position: relative;
}
.do-hist-wk .wk-num { font-family: var(--font-mono); font-size: 0.72rem; font-weight: 800; letter-spacing: 0.08em; color: var(--dm-text-muted); }
.do-hist-wk .dot {
  position: absolute; top: 10px; left: 50%; transform: translateX(-50%);
  width: 10px; height: 10px; border-radius: 999px;
  background: #0f172a; border: 2px solid var(--dm-border-strong);
  z-index: 1;
}
.do-hist-entry.tone-cyan    .do-hist-wk .dot { border-color: var(--dm-cyan); box-shadow: 0 0 8px rgba(34,211,238,0.5); }
.do-hist-entry.tone-emerald .do-hist-wk .dot { border-color: var(--dm-emerald-bright); box-shadow: 0 0 8px rgba(16,185,129,0.5); }
.do-hist-entry.tone-rose    .do-hist-wk .dot { border-color: var(--dm-rose); box-shadow: 0 0 8px rgba(244,63,94,0.5); }
.do-hist-entry.tone-violet  .do-hist-wk .dot { border-color: #a78bfa; box-shadow: 0 0 8px rgba(167,139,250,0.5); }
.do-hist-entry.tone-amber   .do-hist-wk .dot { border-color: var(--dm-amber-bright); box-shadow: 0 0 8px rgba(245,158,11,0.5); }

.do-hist-body { padding-left: 12px; min-width: 0; }
.do-hist-body header { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 6px; }
.do-hist-body .kicker { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.2em; color: var(--dm-text-dead); text-transform: uppercase; }
.do-hist-body .tag {
  margin-left: auto;
  font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.16em; color: var(--dm-text-muted); text-transform: uppercase;
  padding: 2px 8px; border: 1px solid var(--dm-border-strong); border-radius: 999px; background: rgba(2,6,23,0.4);
}
.do-hist-body .title { margin: 0 0 4px; font-family: var(--font-display); font-size: 1.05rem; font-weight: 800; letter-spacing: 0.03em; color: #fff; text-transform: uppercase; line-height: 1.15; }
.do-hist-body .copy { margin: 0; color: var(--dm-text-secondary); font-size: 0.86rem; line-height: 1.5; max-width: 72ch; }

.do-hist-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
  align-items: start;
}

.do-hist-card { display: grid; gap: 0.9rem; min-width: 0; }
.do-hist-card-head { display: grid; gap: 4px; }
.do-hist-card-head h3 { margin: 0; font-family: var(--font-display); font-size: 1.05rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; }
.do-hist-card-note { margin: 0; color: var(--dm-text-muted); font-size: 0.84rem; line-height: 1.5; }

.do-hist-hero-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.8rem;
}

.do-hist-hero-card {
  display: grid;
  gap: 0.35rem;
  padding: 0.95rem 1rem;
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-sm);
  background: rgba(10,22,40,0.92);
}

.do-hist-hero-card.is-current {
  border-color: rgba(34,211,238,0.45);
  box-shadow: 0 0 18px rgba(34,211,238,0.12);
}

.do-hist-hero-label {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.2em;
  color: var(--dm-cyan);
  text-transform: uppercase;
}

.do-hist-hero-season { color: var(--dm-text-muted); font-size: 0.78rem; }
.do-hist-hero-record { font-family: var(--font-display); font-size: 1.35rem; font-weight: 900; letter-spacing: 0.03em; color: #fff; text-transform: uppercase; }
.do-hist-hero-meta { display: flex; gap: 8px; flex-wrap: wrap; color: var(--dm-text-secondary); font-size: 0.76rem; }

.do-hist-list { display: grid; gap: 0.75rem; }

.do-hist-list-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.85rem 0.95rem;
  border: 1px solid rgba(30,41,59,0.9);
  border-radius: var(--radius-sm);
  background: rgba(10,22,40,0.78);
}

.do-hist-list-row .main,
.do-hist-list-row .side {
  display: grid;
  gap: 4px;
  min-width: 0;
}

.do-hist-list-row .main strong {
  font-family: var(--font-display);
  font-size: 0.88rem;
  font-weight: 800;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  color: #fff;
}

.do-hist-list-row .meta { color: var(--dm-text-secondary); font-size: 0.8rem; line-height: 1.45; }
.do-hist-list-row .side { justify-items: end; text-align: right; }
.do-hist-list-row .note { color: var(--dm-text-muted); font-size: 0.74rem; line-height: 1.35; }

.do-hist-directory {
  display: flex;
  gap: 0.55rem;
  flex-wrap: wrap;
}

.do-hist-directory-btn {
  border: 1px solid rgba(51,65,85,0.95);
  border-radius: 4px;
  background: rgba(15,23,42,0.92);
  color: #cbd5e1;
  cursor: pointer;
  font-family: var(--font-display);
  font-size: 0.76rem;
  letter-spacing: 0.08em;
  padding: 0.5rem 0.75rem;
  text-transform: uppercase;
  transition: border-color 140ms ease, color 140ms ease, background 140ms ease;
}

.do-hist-directory-btn:hover {
  border-color: rgba(34,211,238,0.45);
  color: #f8fafc;
  background: rgba(34,211,238,0.08);
}

.do-hist-banners {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.do-hist-banner {
  width: 118px;
  min-height: 112px;
  display: grid;
  align-content: start;
  gap: 6px;
  padding: 0.85rem 0.8rem;
  border: 1px solid rgba(30,41,59,0.9);
  border-radius: var(--radius-sm);
  background: rgba(10,22,40,0.78);
}

.do-hist-banner.is-title { border-color: rgba(245,158,11,0.4); box-shadow: 0 0 18px rgba(245,158,11,0.08); }
.do-hist-banner.is-award { border-color: rgba(34,211,238,0.3); }
.do-hist-banner-empty { border-style: dashed; background: rgba(2,6,23,0.35); }

.do-hist-banner-type {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--dm-text-dead);
}

.do-hist-banner-label {
  font-family: var(--font-display);
  font-size: 0.88rem;
  font-weight: 800;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  color: #fff;
  line-height: 1.2;
}

.do-hist-banner-season { color: var(--dm-text-muted); font-size: 0.75rem; line-height: 1.35; }

.do-hist-modal-body { width: min(100%, 56rem); }
.do-hist-modal-header { display: grid; gap: 6px; margin-bottom: 1rem; padding-right: 4.5rem; }
.do-hist-modal-title { margin: 0; font-family: var(--font-display); font-size: 1.4rem; font-weight: 900; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; }

/* ============================================================
   DYNASTY OFFICE — STAFF TAB
   ============================================================ */
.do-staff-glance {
  display: grid; grid-template-columns: repeat(4, minmax(0, 1fr));
  border: 1px solid var(--dm-border); border-radius: var(--radius-md);
  background: rgba(15,23,42,0.7); overflow: hidden;
}
.do-staff-glance .cell { padding: 1rem 1.1rem; border-left: 1px solid var(--dm-border); display: grid; gap: 6px; align-content: start; }
.do-staff-glance .cell:first-child { border-left: 0; }
.do-staff-glance .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.22em; color: var(--dm-cyan); text-transform: uppercase; }
.do-staff-glance .val { font-family: var(--font-mono); font-size: 1.8rem; font-weight: 900; color: #fff; letter-spacing: 0; line-height: 1; font-variant-numeric: tabular-nums; }
.do-staff-glance .val span { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.18em; color: var(--dm-text-muted); margin-left: 6px; font-weight: 700; }
.do-staff-glance .trend { font-family: var(--font-mono); font-size: 0.7rem; color: var(--dm-text-muted); }
.do-staff-glance .trend.ok { color: var(--dm-emerald-bright); }

.do-staff-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
  gap: 1rem;
}
.do-staff-card {
  border: 1px solid var(--dm-border);
  border-left: 2px solid var(--dm-cyan);
  border-radius: var(--radius-md);
  background: rgba(15,23,42,0.7);
  padding: 1.1rem;
  display: grid; gap: 0.7rem;
}
.do-staff-card-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
.do-staff-card .name { margin: 4px 0 0; font-family: var(--font-display); font-size: 1.15rem; font-weight: 800; letter-spacing: 0.03em; text-transform: uppercase; color: #fff; line-height: 1.1; }
.do-staff-card .rating { display: grid; justify-items: end; gap: 2px; }
.do-staff-card .rating .num { font-family: var(--font-mono); font-size: 1.8rem; font-weight: 900; color: var(--dm-cyan-bright); line-height: 1; font-variant-numeric: tabular-nums; }
.do-staff-card .rating .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.18em; color: var(--dm-text-dead); text-transform: uppercase; }
.do-staff-card .voice { margin: 0; color: var(--dm-text-secondary); font-size: 0.86rem; line-height: 1.45; font-style: italic; }
.do-staff-card .specs { display: flex; gap: 4px; flex-wrap: wrap; }
.do-staff-card .meta {
  display: grid; grid-template-columns: 1fr 1fr; gap: 6px 14px;
  margin: 0;
  padding: 0.5rem 0; border-top: 1px solid var(--dm-border); border-bottom: 1px solid var(--dm-border);
}
.do-staff-card .meta > div { display: grid; gap: 2px; }
.do-staff-card .meta dt { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.18em; color: var(--dm-text-dead); text-transform: uppercase; }
.do-staff-card .meta dd { margin: 0; font-family: var(--font-mono); font-size: 0.82rem; color: #f1f5f9; font-weight: 600; }
.do-staff-card .impact { display: grid; gap: 4px; }
.do-staff-card .impact .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; color: var(--dm-cyan); text-transform: uppercase; }
.do-staff-card .impact .val { font-family: var(--font-body); font-size: 0.84rem; color: var(--dm-text-secondary); line-height: 1.4; }

.do-vacancy-card, .do-pipeline-card {
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: var(--dm-surface-translucent);
  overflow: hidden;
}
.do-vac-list, .do-pipe-list { display: grid; }
.do-vac-row {
  display: grid; grid-template-columns: 1fr auto;
  gap: 14px; align-items: center;
  padding: 0.9rem 1.2rem;
  border-top: 1px solid rgba(30,41,59,0.45);
}
.do-vac-row:first-child { border-top: 0; }
.do-vac-row.priority-high  { border-left: 2px solid var(--dm-amber); }
.do-vac-row.priority-medium { border-left: 2px solid var(--dm-text-dead); }
.do-vac-id { display: grid; gap: 4px; min-width: 0; }
.do-vac-id .dept { font-family: var(--font-display); font-size: 0.95rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: #f1f5f9; }
.do-vac-id .note { font-size: 0.8rem; color: var(--dm-text-muted); line-height: 1.45; }
.do-vac-action { display: flex; gap: 8px; align-items: center; flex-direction: column; align-items: flex-end; }
.do-vac-action .pr { font-family: var(--font-mono); font-size: 0.58rem; font-weight: 800; letter-spacing: 0.16em; padding: 2px 7px; border-radius: 2px; border: 1px solid; text-transform: uppercase; }
.do-vac-action .pr-high   { color: var(--dm-amber-bright); border-color: rgba(245,158,11,0.5); background: rgba(245,158,11,0.10); }
.do-vac-action .pr-medium { color: var(--dm-text-muted); border-color: var(--dm-border-strong); background: rgba(2,6,23,0.4); }

.do-pipe-row {
  display: grid; grid-template-columns: 1fr auto;
  gap: 12px; align-items: center;
  padding: 0.85rem 1.2rem;
  border-top: 1px solid rgba(30,41,59,0.45);
}
.do-pipe-row:first-child { border-top: 0; }
.do-pipe-id { display: grid; gap: 2px; min-width: 0; }
.do-pipe-id .name { font-family: var(--font-display); font-size: 0.95rem; font-weight: 800; letter-spacing: 0.03em; text-transform: uppercase; color: #fff; }
.do-pipe-id .dept { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.14em; color: var(--dm-cyan); text-transform: uppercase; }
.do-pipe-id .note { font-size: 0.78rem; color: var(--dm-text-muted); line-height: 1.45; }
.do-pipe-meta { display: grid; gap: 4px; justify-items: end; }
.do-pipe-meta .rating { font-family: var(--font-mono); font-size: 1.2rem; font-weight: 900; color: #f1f5f9; font-variant-numeric: tabular-nums; line-height: 1; }
.do-pipe-meta .rating small { font-size: 0.55rem; letter-spacing: 0.18em; color: var(--dm-text-dead); margin-left: 4px; font-weight: 700; }
.do-pipe-meta .stage {
  font-family: var(--font-mono); font-size: 0.58rem; font-weight: 800; letter-spacing: 0.16em;
  padding: 2px 7px; border-radius: 2px; border: 1px solid; text-transform: uppercase;
}
.do-pipe-meta .stage-interview  { color: var(--dm-cyan-bright); border-color: rgba(34,211,238,0.45); background: rgba(34,211,238,0.10); }
.do-pipe-meta .stage-background { color: var(--dm-amber-bright); border-color: rgba(245,158,11,0.45); background: rgba(245,158,11,0.10); }
.do-pipe-meta .stage-offer-sent { color: var(--dm-emerald-bright); border-color: rgba(16,185,129,0.45); background: rgba(16,185,129,0.10); }

/* ============================================================
   DYNASTY OFFICE — BUDGET TAB
   ============================================================ */
.do-budget-glance {
  display: grid; grid-template-columns: minmax(0, 2fr) repeat(3, minmax(0, 1fr));
  border: 1px solid var(--dm-border); border-radius: var(--radius-md);
  background: rgba(15,23,42,0.7); overflow: hidden;
}
.do-budget-glance .cell { padding: 1.1rem 1.2rem; border-left: 1px solid var(--dm-border); display: grid; gap: 6px; align-content: start; }
.do-budget-glance .cell:first-child { border-left: 0; }
.do-budget-glance .lbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.22em; color: var(--dm-cyan); text-transform: uppercase; }
.do-budget-glance .val { font-family: var(--font-mono); font-size: 1.8rem; font-weight: 900; color: #f8fafc; line-height: 1; font-variant-numeric: tabular-nums; }
.do-budget-glance .sub { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.06em; color: var(--dm-text-muted); }
.do-budget-glance .trend { font-family: var(--font-mono); font-size: 0.7rem; color: var(--dm-text-muted); }
.do-budget-glance .trend.ok { color: var(--dm-emerald-bright); }
.do-budget-glance .cell.big .val { font-size: 2.4rem; }

.do-budget-glance .budget-bar {
  position: relative; margin-top: 6px;
  height: 10px; border-radius: 2px;
  background: var(--dm-surface-elevated);
  overflow: hidden;
  border: 1px solid var(--dm-border);
}
.do-budget-glance .budget-bar .fill { display: block; height: 100%; background: linear-gradient(90deg, var(--dm-cyan), var(--dm-cyan-bright)); }
.do-budget-glance .budget-bar-meta { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.68rem; color: var(--dm-text-muted); margin-top: 2px; }
.do-budget-glance .budget-bar-meta b { color: #fff; font-weight: 800; }
.do-budget-glance .budget-bar-meta .dim { color: var(--dm-emerald-bright); }

.do-budget-card {
  border: 1px solid var(--dm-border);
  border-radius: var(--radius-md);
  background: var(--dm-surface-translucent);
  overflow: hidden;
}

.do-budget-table { width: 100%; border-collapse: collapse; }
.do-budget-table thead th {
  padding: 0.65rem 1rem; text-align: left;
  font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dm-text-dead); font-weight: 700;
  background: rgba(2,6,23,0.55); border-bottom: 1px solid var(--dm-border);
}
.do-budget-table thead th.num { text-align: right; }
.do-budget-table tbody tr { border-bottom: 1px solid rgba(30,41,59,0.45); }
.do-budget-table tbody tr:last-child { border-bottom: 0; }
.do-budget-table td { padding: 0.85rem 1rem; vertical-align: middle; }
.do-budget-table td.num { text-align: right; font-variant-numeric: tabular-nums; }
.do-budget-table td.note { color: var(--dm-text-muted); font-size: 0.78rem; max-width: 32ch; line-height: 1.4; }
.do-budget-table .mono { font-family: var(--font-mono); color: #f1f5f9; }
.do-budget-table .mono.strong { font-weight: 800; }
.do-budget-table .mono.warn { color: var(--dm-amber-bright); }

.do-bud-cat { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-display); font-size: 0.92rem; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; color: #f1f5f9; }
.do-bud-cat .pip { width: 8px; height: 8px; border-radius: 999px; flex-shrink: 0; }
.do-bud-cat.tone-cyan    .pip { background: var(--dm-cyan); box-shadow: 0 0 6px rgba(34,211,238,0.5); }
.do-bud-cat.tone-emerald .pip { background: var(--dm-emerald-bright); }
.do-bud-cat.tone-violet  .pip { background: #a78bfa; }
.do-bud-cat.tone-amber   .pip { background: var(--dm-amber-bright); }
.do-bud-cat.tone-rose    .pip { background: var(--dm-rose); }

.do-bud-track {
  position: relative; display: inline-block;
  width: 140px; height: 8px; border-radius: 999px;
  background: var(--dm-surface-elevated); overflow: hidden; vertical-align: middle;
}
.do-bud-track .fill { display: block; height: 100%; border-radius: 999px; }
.do-bud-track .fill.tone-cyan    { background: var(--dm-cyan); }
.do-bud-track .fill.tone-emerald { background: var(--dm-emerald-bright); }
.do-bud-track .fill.tone-violet  { background: #a78bfa; }
.do-bud-track .fill.tone-amber   { background: var(--dm-amber-bright); }
.do-bud-track .fill.tone-rose    { background: var(--dm-rose); }
.do-bud-track .cap-mark { position: absolute; top: -3px; bottom: -3px; width: 2px; background: var(--dm-text-dead); }
.do-bud-pct { display: inline-block; margin-left: 10px; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 800; color: var(--dm-text-muted); font-variant-numeric: tabular-nums; }

.do-tx-list { list-style: none; padding: 0; margin: 0; }
.do-tx-row {
  display: grid; grid-template-columns: 50px 110px 1fr auto;
  gap: 14px; align-items: center;
  padding: 0.7rem 1.2rem;
  border-top: 1px solid rgba(30,41,59,0.45);
}
.do-tx-row:first-child { border-top: 0; }
.do-tx-row .wk { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.12em; color: var(--dm-cyan); text-transform: uppercase; font-weight: 700; }
.do-tx-row .type { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.16em; color: var(--dm-text-muted); text-transform: uppercase; }
.do-tx-row .body { display: grid; gap: 2px; min-width: 0; }
.do-tx-row .body .who { font-family: var(--font-display); font-size: 0.88rem; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; color: #f1f5f9; }
.do-tx-row .body .note { font-size: 0.76rem; color: var(--dm-text-muted); }
.do-tx-row .amt { font-family: var(--font-mono); font-size: 1rem; font-weight: 800; font-variant-numeric: tabular-nums; }
.do-tx-row.is-debit  .amt { color: var(--dm-rose); }
.do-tx-row.is-credit .amt { color: var(--dm-emerald-bright); }

@media (max-width: 1180px) {
  .do-tabs {
    flex-wrap: wrap;
    gap: 8px;
    padding: 0 0 0.7rem;
  }
  .do-tabs-spacer { display: none; }
  .do-tabs .dm-btn { margin-left: auto; }
  .do-tabs-note {
    width: 100%;
    padding: 0;
    text-align: right;
  }
  .do-hist-grid { grid-template-columns: 1fr; }
  .do-hist-hero-grid { grid-template-columns: 1fr; }
  .do-hist-glance    { grid-template-columns: repeat(3, 1fr); }
  .do-hist-glance .cell:nth-child(n+4) { border-top: 1px solid var(--dm-border); }
  .do-staff-glance, .do-budget-glance { grid-template-columns: repeat(2, 1fr); }
  .do-budget-glance .cell.big { grid-column: 1 / -1; }
}
@media (max-width: 720px) {
  .do-tabs {
    align-items: center;
    row-gap: 10px;
  }
  .do-tab {
    padding-left: 0.9rem;
    padding-right: 0.9rem;
  }
  .do-tabs .dm-btn {
    margin-left: 0;
    width: 100%;
    justify-content: center;
  }
  .do-tabs-note { text-align: left; }
  .do-hist-glance, .do-staff-glance, .do-budget-glance { grid-template-columns: 1fr; }
  .do-hist-glance .cell, .do-staff-glance .cell, .do-budget-glance .cell { border-left: 0; border-top: 1px solid var(--dm-border); }
  .do-hist-glance .cell:first-child, .do-staff-glance .cell:first-child, .do-budget-glance .cell:first-child { border-top: 0; }
  .do-hist-list-row { flex-direction: column; }
  .do-hist-list-row .side { justify-items: start; text-align: left; }
  .do-hist-directory-btn { width: 100%; text-align: left; }
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 1180px) {
  .cc-hero { grid-template-columns: 1fr; }
  .cc-hero-right { border-left: 0; border-top: 1px solid var(--dm-border); }
  .cc-body { grid-template-columns: 1fr 1fr; }
  .cc-body .cc-lock { grid-column: span 2; }
  .cc-id-strip { grid-template-columns: repeat(3, 1fr); }
  .analysis-row, .do-summary-row { grid-template-columns: 1fr; }
  .mr-shell { grid-template-columns: 1fr; }
  .mr-scoreboard { grid-template-columns: 1fr; }
  .mr-score { border-left: 0; border-right: 0; border-top: 1px solid var(--dm-border); border-bottom: 1px solid var(--dm-border); padding: 0.8rem 1rem; }
  .mr-team.away { text-align: left; justify-items: start; border-right: 0; border-left: 2px solid var(--dm-blue); }
  .mr-sidebar-wrap { max-height: none; min-height: 0; }
}
@media (max-width: 720px) {
  .app-shell { flex-direction: column; }
  .left-nav { width: 100%; height: auto; position: static; border-right: 0; border-bottom: 1px solid var(--dm-border); }
