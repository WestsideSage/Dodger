    player_id: str
    ratings_tier: str
    archetype_tier: str
    traits_tier: str
    trajectory_tier: str
    scout_points: Dict[str, int]
    last_updated_week: int


@dataclass(frozen=True)
class ScoutAssignment:
    scout_id: str
