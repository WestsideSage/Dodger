              <h3>Top {playoffLine} Race</h3>
            </div>
            <div className="ls-tb-list">
              {tiebreakRows.map((standing) => {
                const isSafe = standing.rank <= playoffLine;
                return (
                  <div
                    key={`tb-${standing.club_id}`}
                    className="ls-tb-row"
