@import "tailwindcss";

@theme {
  --color-cream: #F3EEE2;
  --color-paper: #FFF9EC;
  --color-charcoal: #232126;
  --color-muted: #5B5660;
  --color-brick: #B44E35;
  --color-orange: #CF6D36;
  --color-mustard: #D8A232;
  --color-teal: #438F86;
  --color-sage: #728F5B;
  --color-gym: #496F9A;
  --color-danger: #C94E3F;
  --color-line: #E7D8C2;
  --color-border: #2D2A31;

  --font-sans: 'Inter', 'Segoe UI', system-ui, sans-serif;
  --font-display: 'Oswald', 'Bahnschrift SemiBold', 'Arial Narrow', sans-serif;

  /* DM v2 — Dark shell palette */
  --color-dm-bg: #020617;
  --color-dm-surface-primary: #0f172a;
  --color-dm-surface-elevated: #1e293b;
  --color-dm-border: #1e293b;
  --color-dm-border-strong: #334155;

  /* DM v2 — Text */
  --color-dm-text: #ffffff;
  --color-dm-text-secondary: #cbd5e1;
  --color-dm-text-muted: #94a3b8;
  --color-dm-text-dead: #64748b;

  /* DM v2 — Accents */
  --color-dm-cyan: #22d3ee;
  --color-dm-orange: #f97316;
  --color-dm-rose: #f43f5e;
  --color-dm-emerald: #10b981;
  --color-dm-amber: #f59e0b;
  --color-dm-violet: #a78bfa;

  /* DM v2 — Font families */
  --font-body: 'Inter', ui-sans-serif, system-ui;
  --font-mono-data: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', monospace;

  /* DM v2 — Glow shadows */
  --shadow-glow-cyan: 0 0 18px rgba(6,182,212,0.28);
  --shadow-glow-orange: 0 0 18px rgba(249,115,22,0.28);
  --shadow-glow-rose: 0 0 18px rgba(244,63,94,0.28);
}

:root {
  --shadow-panel: 0 10px 0 rgba(35, 33, 38, 0.08);
  --shadow-button: 0 4px 0 rgba(35, 33, 38, 0.12);

  /* --dm-* aliases consumed by the design-kit cc-* rules */
  --dm-bg: #020617;
  --dm-surface-primary: #0f172a;
  --dm-surface-elevated: #1e293b;
  --dm-surface-translucent: rgba(15, 23, 42, 0.65);
  --dm-border: #1e293b;
  --dm-border-strong: #334155;
  --dm-text: #ffffff;
  --dm-text-secondary: #cbd5e1;
  --dm-text-muted: #94a3b8;
  --dm-text-dead: #64748b;
  --dm-cyan: #22d3ee;
  --dm-cyan-bright: #67e8f9;
  --dm-orange: #f97316;
  --dm-orange-hover: #fb923c;
  --dm-orange-soft: rgba(249, 115, 22, 0.15);
  --dm-rose: #f43f5e;
  --dm-emerald: #10b981;
  --dm-emerald-bright: #34d399;
  --dm-amber: #f59e0b;
  --dm-amber-bright: #fbbf24;
  --dm-violet: #a78bfa;
  --radius-md: 0.5rem;
  --radius-lg: 0.75rem;
  --font-mono: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', monospace;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: #020617;
  color: #ffffff;
  font-family: var(--font-body);
  -webkit-font-smoothing: antialiased;
}

button,
input {
  font: inherit;
}

button:focus-visible,
[role="button"]:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible {
  outline: 2px solid rgba(34, 211, 238, 0.9);
  outline-offset: 2px;
}

.app-shell {
  background:
    linear-gradient(115deg, rgba(255, 249, 236, 0.94), rgba(243, 238, 226, 0.86)),
    radial-gradient(circle at 8% 12%, rgba(216, 162, 50, 0.18), transparent 26rem),
    radial-gradient(circle at 92% 8%, rgba(67, 143, 134, 0.14), transparent 24rem),
    repeating-linear-gradient(90deg, rgba(45, 42, 49, 0.045) 0 1px, transparent 1px 5.5rem);
}

.site-header {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 1rem;
  border-bottom: 3px solid var(--color-border);
  padding-bottom: 1rem;
}

.nav-rail {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.5rem;
}

.nav-tab {
  min-height: 3.5rem;
  border: 1px solid var(--color-border);
  border-radius: 0.375rem;
  background: var(--color-paper);
  color: var(--color-charcoal);
  box-shadow: var(--shadow-button);
  cursor: pointer;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0.1rem;
  padding: 0.6rem 0.85rem;
  text-align: left;
  transition: transform 150ms ease, background-color 150ms ease, color 150ms ease;
}

.nav-tab:hover {
  background: var(--color-cream);
  transform: translateY(-1px);
}

.nav-tab span {
  font-family: var(--font-display);
  font-size: 0.8rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.nav-tab small {
  color: var(--color-muted);
  font-size: 0.7rem;
}

.nav-tab-active {
  background: var(--color-charcoal);
  color: var(--color-paper);
}

.nav-tab-active small {
  color: color-mix(in srgb, var(--color-paper) 72%, transparent);
}

.workspace-panel {
  min-height: 38rem;
  border: 1px solid var(--color-border);
  border-radius: 0.5rem;
  background:
    linear-gradient(180deg, rgba(255, 249, 236, 0.94), rgba(255, 249, 236, 0.98)),
    linear-gradient(90deg, transparent 0 49%, rgba(45, 42, 49, 0.05) 49% 51%, transparent 51% 100%);
  box-shadow: 0 18px 0 rgba(35, 33, 38, 0.08);
  padding: 1rem;
}

.dashboard-header {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 1rem;
  border-bottom: 1px solid var(--color-border);
  padding-bottom: 1rem;
}

.court-panel {
  background:
    linear-gradient(90deg, transparent 0 49.5%, rgba(180, 78, 53, 0.32) 49.5% 50.5%, transparent 50.5% 100%),
    repeating-linear-gradient(0deg, rgba(45, 42, 49, 0.04) 0 1px, transparent 1px 2.2rem),
    var(--color-cream);
}

.proof-list {
  display: flex;
  min-height: 16rem;
  max-height: 24rem;
  flex-direction: column;
  gap: 0.5rem;
  overflow: auto;
}

.proof-list-item {
  display: grid;
  min-height: 4.25rem;
  grid-template-columns: 5.5rem minmax(0, 1fr);
  align-items: center;
  gap: 0.75rem;
  border: 1px solid var(--color-line);
  border-radius: 0.375rem;
  background: var(--color-paper);
  color: var(--color-charcoal);
  padding: 0.65rem 0.75rem;
  text-align: left;
  cursor: pointer;
}

.proof-list-item span {
  font-family: var(--font-display);
  font-size: 0.7rem;
  text-transform: uppercase;
  color: var(--color-brick);
}

.proof-list-item strong {
  font-size: 0.88rem;
  line-height: 1.25;
}

.proof-list-item-active {
  border-color: var(--color-border);
  background: color-mix(in srgb, var(--color-mustard) 22%, var(--color-paper));
}

.proof-inspector {
  display: grid;
  min-height: 24rem;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.75rem;
  margin-top: 0.75rem;
}

.proof-context-block {
  min-height: 7rem;
  border-top: 1px solid var(--color-line);
  padding-top: 0.75rem;
}

.proof-inspector > *:first-child,
.proof-inspector > *:nth-child(2) {
  grid-column: 1 / -1;
}

.schedule-row {
  display: grid;
  grid-template-columns: 76px minmax(0, 1fr) auto;
  align-items: center;
  gap: 0.75rem;
}

.tactic-range {
  appearance: none;
  height: 6px;
  border-radius: 9999px;
  background: #1e293b;
  outline: none;
}

.tactic-range::-webkit-slider-thumb {
  appearance: none;
  width: 1rem;
  height: 1rem;
  border: none;
  border-radius: 999px;
  background: #f97316;
  box-shadow: 0 0 10px rgba(249,115,22,0.4);
  cursor: pointer;
  transition: transform 0.1s;
}

.tactic-range::-webkit-slider-thumb:hover {
  transform: scale(1.15);
}

.tactic-range::-moz-range-thumb {
  width: 1rem;
  height: 1rem;
  border: none;
  border-radius: 999px;
  background: #f97316;
  box-shadow: 0 0 10px rgba(249,115,22,0.4);
  cursor: pointer;
  transition: transform 0.1s;
}

.tactic-range::-moz-range-thumb:hover {
  transform: scale(1.15);
}

.tactic-range:focus-visible {
  outline: 2px solid #f97316;
  outline-offset: 2px;
}

@media (min-width: 720px) {
  .nav-rail {
    grid-template-columns: repeat(6, minmax(0, 1fr));
  }

  .dashboard-header {
    flex-direction: row;
    align-items: end;
  }

  .workspace-panel {
    padding: 1.5rem;
  }
}

@media (max-width: 520px) {
  .site-header h1 {
    font-size: 2rem;
  }

  .workspace-panel {
    padding: 0.75rem;
  }

  .nav-tab {
    min-height: 3rem;
  }

  .schedule-row {
    grid-template-columns: 1fr;
    align-items: start;
  }

  .proof-list-item,
  .proof-inspector {
    grid-template-columns: 1fr;
  }

  .proof-inspector > *:first-child,
  .proof-inspector > *:nth-child(2) {
    grid-column: auto;
  }
}

